static void UpdateScrollBounds(WindowCtx* c, const Layout* L) {
    int maxR = 0; for (int i=0;i<c->itemCount;++i) { if (c->items[i].parent == c->rootId && c->items[i].type != IT_TRASH) { if (c->items[i].gridRow > maxR) maxR = c->items[i].gridRow; } }
    int contentH = L->yStart + (maxR + 1) * L->rowH; int viewH = L->content.bottom - L->content.top;
    c->maxScroll = max(0, contentH - viewH + S(30)); if (c->scrollY > c->maxScroll) { c->scrollY = c->maxScroll; } if (c->scrollY < 0) { c->scrollY = 0; }
}

