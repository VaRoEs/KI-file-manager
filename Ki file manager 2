    }
    if (c->lasso) { HPEN pen = CreatePen(PS_DOT, 1, RGB(0,0,0)); HGDIOBJ op = SelectObject(dc, pen); Rectangle(dc, c->lassoRect.left, c->lassoRect.top, c->lassoRect.right, c->lassoRect.bottom); SelectObject(dc, op); DeleteObject(pen); }
