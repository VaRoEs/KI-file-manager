static void DebugPrint(const wchar_t* msg) {
    wchar_t buffer[512] = {0};
    wcscpy(buffer, msg);
    wcscat(buffer, L"\n");
    OutputDebugStringW(buffer);
}

int WINAPI wWinMain(HINSTANCE hInst, HINSTANCE hPrevInst, PWSTR lpCmdLine, int nCmdShow) {
    DebugPrint(L"=== KI Program Started ===");
    
    CoInitializeEx(NULL, COINIT_APARTMENTTHREADED); 
    g_hInst = hInst; 
    SetDpiAware();
    
    DebugPrint(L"DPI set");

    g_hCancelEvent = CreateEventW(NULL, TRUE, FALSE, NULL);
    DebugPrint(L"Cancel event created");
    
    InitializeCriticalSection(&g_indexCs);
    DebugPrint(L"Critical section initialized");

    LoadKiSettings();
    DebugPrint(L"Settings loaded");
    
    WNDCLASSW wc = {0}; 
    wc.style = CS_HREDRAW|CS_VREDRAW|CS_DBLCLKS; 
    wc.lpfnWndProc = WndProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kWndClass; 
    if (!RegisterClassW(&wc)) {
        DebugPrint(L"Failed to register main window class!");
        return 1;
    }
    DebugPrint(L"Main window class registered");
    
    wc = (WNDCLASSW){0}; 
    wc.lpfnWndProc = TopBarProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kTopBarClass; 
    if (!RegisterClassW(&wc)) {
        DebugPrint(L"Failed to register topbar class!");
        return 1;
    }
    DebugPrint(L"Topbar class registered");
    
    wc = (WNDCLASSW){0}; 
    wc.lpfnWndProc = MiniDlgProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kDlgClass; 
    RegisterClassW(&wc);
    
    wc = (WNDCLASSW){0}; 
    wc.lpfnWndProc = MenuProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kMenuClass; 
    RegisterClassW(&wc);
    
    wc = (WNDCLASSW){0}; 
    wc.lpfnWndProc = AppleProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kAppleClass; 
    RegisterClassW(&wc);
    
    wc = (WNDCLASSW){0}; 
    wc.lpfnWndProc = ApplePopupProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kApplePopupClass; 
    RegisterClassW(&wc);
    
    wc = (WNDCLASSW){0}; 
    wc.lpfnWndProc = ProgressProc; 
    wc.hInstance = hInst; 
    wc.hCursor = LoadCursor(NULL, IDC_ARROW); 
    wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); 
    wc.lpszClassName = kProgClass; 
    RegisterClassW(&wc);
    
    DebugPrint(L"All window classes registered");
    
    int barW = S(720), barH = S(140); 
    int sx = GetSystemMetrics(SM_CXSCREEN); 
    int x = (sx - barW)/2;
    g_topBar = CreateWindowExW(WS_EX_TOPMOST|WS_EX_TOOLWINDOW, kTopBarClass, L"", WS_POPUP, x, S(10), barW, barH, NULL, NULL, g_hInst, NULL); 
    if (!g_topBar) {
        DebugPrint(L"Failed to create topbar window!");
    } else {
        ShowWindow(g_topBar, SW_SHOWNOACTIVATE); 
        UpdateWindow(g_topBar);
        DebugPrint(L"Topbar created and shown");
    }
    
    DWORD style = WS_POPUP; 
    int W = S(760), H = S(500); 
    int sx_main = GetSystemMetrics(SM_CXSCREEN);
    int sy_main = GetSystemMetrics(SM_CYSCREEN);
    int wx = (sx_main - W) / 2;
    int wy = (sy_main - H) / 2;
    
    HWND win = CreateWindowW(kWndClass, L"KI Explorer", style, wx, wy, W, H, NULL, NULL, g_hInst, NULL); 
    if (!win) {
        DebugPrint(L"Failed to create main window!");
        return 1;
    }
    DebugPrint(L"Main window created");
    
    ShowWindow(win, SW_SHOW); 
    UpdateWindow(win);
    DebugPrint(L"Main window shown with SW_SHOW");
    
    if (!g_appleWnd) { 
        g_appleWnd = CreateWindowExW(WS_EX_TOPMOST|WS_EX_TOOLWINDOW, kAppleClass, L"", WS_POPUP, S(10), S(10), S(56), S(56), NULL, NULL, g_hInst, NULL); 
        if (g_appleWnd) {
            ShowWindow(g_appleWnd, SW_SHOWNOACTIVATE); 
            UpdateWindow(g_appleWnd);
            DebugPrint(L"Apple button created");
        }
    }
    
    DebugPrint(L"Entering message loop");
    
    MSG msg; 
    while (GetMessageW(&msg, NULL, 0, 0)) { 
        TranslateMessage(&msg); 
        DispatchMessageW(&msg); 
    } 
    
    DebugPrint(L"Message loop ended, cleaning up");
    
    if (g_hCancelEvent) {
        SetEvent(g_hCancelEvent);
        CloseHandle(g_hCancelEvent);
        g_hCancelEvent = NULL;
    }
    
    if (g_stringArena) {
        HeapFree(GetProcessHeap(), 0, g_stringArena);
        g_stringArena = NULL;
    }
    if (g_indexCache) {
        HeapFree(GetProcessHeap(), 0, g_indexCache);
        g_indexCache = NULL;
    }
    
    DeleteCriticalSection(&g_indexCs);
    CoUninitialize(); 
    
    DebugPrint(L"KI Program exited cleanly");
    return 0;
}
