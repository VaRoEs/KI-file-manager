    HFONT fontTitle = NULL; PickClassicFont(&fontTitle, 14, TRUE); HGDIOBJ oldFont = SelectObject(dc, fontTitle); SetTextColor(dc, RGB(0,0,0)); SetBkMode(dc, TRANSPARENT); const wchar_t* title = (c->rootId==-2) ? L"Search Results" : ((c->rootId<0) ? (lstrcmpW(c->fsRootPath, L":Computer:") == 0 ? L"Computer" : L"KI") : c->items[c->rootId].name); TextOutAlign(dc, (L->titleBar.left+L->titleBar.right)/2, L->titleBar.top + S(6), title, TA_TOP | TA_CENTER); SelectObject(dc, oldFont); DeleteObject(fontTitle);
