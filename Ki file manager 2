static void FS_FormatSizeDual(ULONGLONG bytes, wchar_t* out, int outc) {
    if (bytes < 1024) _snwprintf(out, outc-1, L"%llu B", (unsigned long long)bytes); else if (bytes < 1024*1024) _snwprintf(out, outc-1, L"%.2f KB", bytes / 1024.0); else if (bytes < 1024*1024*1024) _snwprintf(out, outc-1, L"%.2f MB", bytes / 1048576.0); else _snwprintf(out, outc-1, L"%.2f GB", bytes / 1073741824.0);
    out[outc-1] = 0;
}

static void FS_ScanDirForRank(const wchar_t* dir, ULONGLONG targetSize, ULONGLONG* totalFiles, ULONGLONG* greaterCount) {
    wchar_t mask[MAX_PATH] = {0}; _snwprintf(mask, MAX_PATH-1, L"%s\\*", dir); mask[MAX_PATH-1]=0;
    WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd); if (h==INVALID_HANDLE_VALUE) return;
    do {
        if (FS_IsDotOrDotDot(&fd)) continue;
        wchar_t full[MAX_PATH] = {0}; _snwprintf(full, MAX_PATH-1, L"%s\\%s", dir, fd.cFileName); full[MAX_PATH-1]=0;
        if (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) FS_ScanDirForRank(full, targetSize, totalFiles, greaterCount);
        else { ULARGE_INTEGER li; li.HighPart = fd.nFileSizeHigh; li.LowPart = fd.nFileSizeLow; ULONGLONG sz = li.QuadPart; (*totalFiles)++; if (sz > targetSize) (*greaterCount)++; }
    } while (FindNextFileW(h, &fd)); FindClose(h);
}

static void FS_ComputeDiskRank(const wchar_t* filePath, ULONGLONG fileSize, ULONGLONG* outTotal, ULONGLONG* outRank) {
    *outTotal = 0; *outRank = 0; if (!filePath || !filePath[0]) return;
    wchar_t root[MAX_PATH]={0};
    if (wcslen(filePath) >= 2 && filePath[1]==L':') {
        _snwprintf(root, MAX_PATH-1, L"%c:", filePath[0]); root[2]=0; wchar_t pathRoot[MAX_PATH]; _snwprintf(pathRoot, MAX_PATH-1, L"%s\\", root);
        ULONGLONG total=0, greater=0; FS_ScanDirForRank(pathRoot, fileSize, &total, &greater); *outTotal = total; *outRank  = greater + 1; 
    }
}

