static void SetClipboardText(HWND owner, const wchar_t* text) {
    if (!text || !*text) return;
    if (!OpenClipboard(owner)) return;
    EmptyClipboard();
    SIZE_T bytes = (wcslen(text)+1)*sizeof(wchar_t);
    HGLOBAL h = GlobalAlloc(GMEM_MOVEABLE, bytes);
    if (h) {
        void* p = GlobalLock(h);
        if (p) { memcpy(p, text, bytes); GlobalUnlock(h); SetClipboardData(CF_UNICODETEXT, h); }
        else GlobalFree(h);
    }
    CloseClipboard();
}

static void TrimInPlaceW(wchar_t* s) {
    if (!s) return;
    wchar_t* p = s; while (*p==L' '||*p==L'\t'||*p==L'\r'||*p==L'\n'||*p==L'\"'||*p==L'\'') ++p;
    if (p!=s) { size_t k=0; while (p[k]) { s[k]=p[k]; ++k; } s[k]=0; }
    size_t n = lstrlenW(s);
    while (n>0) {
        wchar_t c = s[n-1];
        if (c==L' '||c==L'\t'||c==L'\r'||c==L'\n'||c==L'\"'||c==L'\'') { s[n-1]=0; --n; }
        else break;
    }
}

static int SplitLinesToArray(const wchar_t* text, wchar_t** outArr, int maxItems) {
    int count = 0; const wchar_t* s = text;
    while (*s && count < maxItems) {
        const wchar_t* e = s; while (*e && *e!=L'\r' && *e!=L'\n') ++e;
        int len = (int)(e - s);
        if (len > 0) {
            outArr[count] = (wchar_t*)LocalAlloc(LMEM_FIXED, (len+1)*sizeof(wchar_t));
            if (outArr[count]) { lstrcpynW(outArr[count], s, len+1); TrimInPlaceW(outArr[count]); if (outArr[count][0]) count++; else { LocalFree(outArr[count]); outArr[count]=NULL; } }
        }
        while (*e==L'\r' || *e==L'\n') ++e;
        s = e;
    } return count;
}

static void FreeArray(wchar_t** arr, int count) { for (int i=0;i<count;i++) if (arr[i]) LocalFree(arr[i]); }

static wchar_t* BuildDoubleNullMultiString(wchar_t** arr, int count) {
    size_t total = 1; for (int i=0;i<count;i++) total += lstrlenW(arr[i]) + 1;
    wchar_t* buf = (wchar_t*)LocalAlloc(LMEM_FIXED, total * sizeof(wchar_t));
    if (!buf) return NULL;
    wchar_t* p = buf; for (int i=0;i<count;i++) { lstrcpyW(p, arr[i]); p += lstrlenW(p)+1; } *p = 0; return buf;
}

static void CreateLink(LPCWSTR lpszPathObj, LPCWSTR lpszPathLink, LPCWSTR lpszDesc) {
    IShellLinkW* psl;
    if (SUCCEEDED(CoCreateInstance(&CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER, &IID_IShellLinkW, (LPVOID*)&psl))) {
        psl->lpVtbl->SetPath(psl, lpszPathObj); psl->lpVtbl->SetDescription(psl, lpszDesc);
        IPersistFile* ppf;
        if (SUCCEEDED(psl->lpVtbl->QueryInterface(psl, &IID_IPersistFile, (LPVOID*)&ppf))) { ppf->lpVtbl->Save(ppf, lpszPathLink, TRUE); ppf->lpVtbl->Release(ppf); }
        psl->lpVtbl->Release(psl);
    }
}

static void* DynGrow(void* ptr, int* capacity, int* count, int elementSize) {
    *capacity *= 2;
    void* newPtr = HeapReAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, ptr, (*capacity) * elementSize);
    if (!newPtr) {
        *capacity /= 2;
        return ptr;
    }
    return newPtr;
}

static void LoadKiSettings(void) {
    wchar_t path[MAX_PATH] = {0};
    GetEnvironmentVariableW(L"USERPROFILE", path, MAX_PATH);
    if (path[0] == 0) {
        lstrcpyW(path, L"C:\\");
    }
    lstrcatW(path, L"\\ki_settings.txt");
    
    WIN32_FILE_ATTRIBUTE_DATA fad;
    if (GetFileAttributesExW(path, GetFileExInfoStandard, &fad)) {
        ULONGLONG curTime = ((ULONGLONG)fad.ftLastWriteTime.dwHighDateTime << 32) | fad.ftLastWriteTime.dwLowDateTime;
        if (curTime == g_lastSettingsTime) return;
        g_lastSettingsTime = curTime;
    } else {
        return;
    }

    FILE* f = _wfopen(path, L"rt,ccs=UTF-8");
    if (!f) return;
    
    g_iconAssocCount = 0;
    wchar_t line[256];
    while (fgetws(line, 256, f)) {
        if (wcsncmp(line, L"TrashSkin=", 10) == 0) {
            g_trashSkin = _wtoi(line + 10);
        } else if (wcsncmp(line, L"DarkMode=", 9) == 0) {
            g_darkMode = _wtoi(line + 9);
        } else if (wcsncmp(line, L"Icon:", 5) == 0) {
            wchar_t* eq = wcschr(line, L'=');
            if (eq && g_iconAssocCount < 64) {
                *eq = 0;
                lstrcpynW(g_iconAssocs[g_iconAssocCount].ext, line + 5, 31);
                CharLowerW(g_iconAssocs[g_iconAssocCount].ext);
                g_iconAssocs[g_iconAssocCount].iconId = _wtoi(eq + 1);
                g_iconAssocCount++;
            }
        }
    }
    fclose(f);
}

static int IndexEntryCompare(const void* a, const void* b) {
    const IndexEntry* ea = (const IndexEntry*)a;
    const IndexEntry* eb = (const IndexEntry*)b;
    if (!ea->path && !eb->path) return 0;
    if (!ea->path) return -1;
    if (!eb->path) return 1;
    return lstrcmpiW(ea->path, eb->path);
}

static void LoadIndexCache_Internal(void) {
    EnsureIndexFile();
    
    wchar_t binFile[MAX_PATH] = {0};
    lstrcpynW(binFile, g_indexFile, MAX_PATH);
    wchar_t* dot = wcsrchr(binFile, L'.');
    if (dot) lstrcpyW(dot, L".bin");
    else lstrcatW(binFile, L".bin");
    
    WIN32_FILE_ATTRIBUTE_DATA fad;
    if (GetFileAttributesExW(binFile, GetFileExInfoStandard, &fad)) {
        ULONGLONG curTime = ((ULONGLONG)fad.ftLastWriteTime.dwHighDateTime << 32) | fad.ftLastWriteTime.dwLowDateTime;
        if (curTime == g_indexFileTime && g_indexCacheLoaded) return;
        g_indexFileTime = curTime;
    } else {
        if (GetFileAttributesExW(g_indexFile, GetFileExInfoStandard, &fad)) {
            ULONGLONG curTime = ((ULONGLONG)fad.ftLastWriteTime.dwHighDateTime << 32) | fad.ftLastWriteTime.dwLowDateTime;
            if (curTime == g_indexFileTime && g_indexCacheLoaded) return;
            g_indexFileTime = curTime;
        } else {
            return;
        }
    }
    
    if (g_stringArena) {
        HeapFree(GetProcessHeap(), 0, g_stringArena);
        g_stringArena = NULL;
    }
    if (g_indexCache) {
        HeapFree(GetProcessHeap(), 0, g_indexCache);
        g_indexCache = NULL;
        g_indexCacheCount = 0;
        g_indexCacheCapacity = 0;
    }
    g_arenaCapacityChars = 0;
    g_arenaOffset = 0;
    
    HANDLE hBinFile = CreateFileW(binFile, GENERIC_READ, FILE_SHARE_READ, NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hBinFile != INVALID_HANDLE_VALUE) {
        DWORD fileSize = GetFileSize(hBinFile, NULL);
        if (fileSize >= sizeof(int)) {
            DWORD bytesRead;
            int count = 0;
            ReadFile(hBinFile, &count, sizeof(int), &bytesRead, NULL);
            if (count > 0 && count < 10000000) {
                size_t arenaSizeChars = 0;
                ReadFile(hBinFile, &arenaSizeChars, sizeof(size_t), &bytesRead, NULL);
                
                if (arenaSizeChars > 0 && arenaSizeChars < 100 * 1024 * 1024 / sizeof(wchar_t)) {
                    g_arenaCapacityChars = arenaSizeChars;
                    g_stringArena = (wchar_t*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, g_arenaCapacityChars * sizeof(wchar_t));
                    if (g_stringArena) {
                        ReadFile(hBinFile, g_stringArena, (DWORD)(g_arenaCapacityChars * sizeof(wchar_t)), &bytesRead, NULL);
                        
                        g_indexCacheCapacity = count + 1000;
                        g_indexCache = (IndexEntry*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, sizeof(IndexEntry) * g_indexCacheCapacity);
                        
                        for (int i = 0; i < count && i < g_indexCacheCapacity; i++) {
                            size_t nameOffset = 0, pathOffset = 0;
                            ReadFile(hBinFile, &nameOffset, sizeof(size_t), &bytesRead, NULL);
                            ReadFile(hBinFile, &pathOffset, sizeof(size_t), &bytesRead, NULL);
                            ReadFile(hBinFile, &g_indexCache[i].size, sizeof(ULONGLONG), &bytesRead, NULL);
                            ReadFile(hBinFile, &g_indexCache[i].inIndex, sizeof(BOOL), &bytesRead, NULL);
                            
                            if (g_stringArena && nameOffset < g_arenaCapacityChars) {
                                g_indexCache[i].name = &g_stringArena[nameOffset];
                            } else {
                                g_indexCache[i].name = NULL;
                            }
                            if (g_stringArena && pathOffset < g_arenaCapacityChars) {
                                g_indexCache[i].path = &g_stringArena[pathOffset];
                            } else {
                                g_indexCache[i].path = NULL;
                            }
                        }
                        g_indexCacheCount = count;
                        
                        qsort(g_indexCache, g_indexCacheCount, sizeof(IndexEntry), IndexEntryCompare);
                        g_indexCacheLoaded = TRUE;
                    }
                }
            }
        }
        CloseHandle(hBinFile);
        if (g_indexCacheLoaded) return;
    }
    
    FILE* f = _wfopen(g_indexFile, L"rt,ccs=UTF-8");
    if (!f) return;
    
    g_arenaCapacityChars = (64 * 1024 * 1024) / sizeof(wchar_t);
    g_stringArena = (wchar_t*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, g_arenaCapacityChars * sizeof(wchar_t));
    g_arenaOffset = 0;
    
    g_indexCacheCapacity = 20000;
    g_indexCache = (IndexEntry*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, sizeof(IndexEntry) * g_indexCacheCapacity);
    g_indexCacheCount = 0;
    
    wchar_t line[2048];
    while (fgetws(line, 2048, f) && g_indexCacheCount < 500000) {
        if (line[0] == L'/' && line[1] == L'/') continue;
        if (line[0] == L'\n' || line[0] == L'\r' || line[0] == 0) continue;
        
        wchar_t* nameStart = line;
        while (*nameStart == L' ' || *nameStart == L'\t') nameStart++;
        
        wchar_t* sep1 = wcsstr(nameStart, L" | ");
        if (!sep1) continue;
        *sep1 = 0;
        wchar_t* name = nameStart;
        
        wchar_t* pathStart = sep1 + 3;
        wchar_t* sep2 = wcsstr(pathStart, L" | ");
        if (!sep2) { *sep1 = L' '; continue; }
        *sep2 = 0;
        wchar_t* path = pathStart;
        
        wchar_t* sizeStr = sep2 + 3;
        TrimInPlaceW(sizeStr);
        TrimInPlaceW(name);
        TrimInPlaceW(path);
        
        ULONGLONG size = _wcstoui64(sizeStr, NULL, 10);
        
        size_t nameLen = wcslen(name) + 1;
        size_t pathLen = wcslen(path) + 1;
        
        if (g_arenaOffset + nameLen + pathLen >= g_arenaCapacityChars) {
            size_t newCapacity = g_arenaCapacityChars * 2;
            wchar_t* newArena = (wchar_t*)HeapReAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, g_stringArena, newCapacity * sizeof(wchar_t));
            if (newArena) {
                if (newArena != g_stringArena) {
                    for (int k = 0; k < g_indexCacheCount; k++) {
                        if (g_indexCache[k].name) g_indexCache[k].name = newArena + (g_indexCache[k].name - g_stringArena);
                        if (g_indexCache[k].path) g_indexCache[k].path = newArena + (g_indexCache[k].path - g_stringArena);
                    }
                    g_stringArena = newArena;
                }
                g_arenaCapacityChars = newCapacity;
            } else {
                *sep1 = L' ';
                *sep2 = L' ';
                continue;
            }
        }
        
        if (g_indexCacheCount >= g_indexCacheCapacity) {
            g_indexCache = (IndexEntry*)DynGrow(g_indexCache, &g_indexCacheCapacity, &g_indexCacheCount, sizeof(IndexEntry));
            if (!g_indexCache) break;
        }
        
        g_indexCache[g_indexCacheCount].name = &g_stringArena[g_arenaOffset];
        lstrcpyW(&g_stringArena[g_arenaOffset], name);
        g_arenaOffset += nameLen;
        
        g_indexCache[g_indexCacheCount].path = &g_stringArena[g_arenaOffset];
        lstrcpyW(&g_stringArena[g_arenaOffset], path);
        g_arenaOffset += pathLen;
        
        g_indexCache[g_indexCacheCount].size = size;
        g_indexCache[g_indexCacheCount].inIndex = TRUE;
        g_indexCacheCount++;
        
        *sep1 = L' ';
        *sep2 = L' ';
    }
    fclose(f);
    
    if (g_indexCacheCount > 0) {
        qsort(g_indexCache, g_indexCacheCount, sizeof(IndexEntry), IndexEntryCompare);
    }
    g_indexCacheLoaded = TRUE;
}

