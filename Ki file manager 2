static ULONGLONG FS_GetFileSizeBytesCorrect(const wchar_t* fullPath) {
    if (!fullPath || !*fullPath) return 0;
    
    // Пробуем через CreateFile (работает на всех дисках)
    HANDLE hFile = CreateFileW(fullPath, GENERIC_READ, FILE_SHARE_READ, NULL, 
                                OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hFile != INVALID_HANDLE_VALUE) {
        LARGE_INTEGER size;
        if (GetFileSizeEx(hFile, &size)) {
            CloseHandle(hFile);
            return size.QuadPart;
        }
        CloseHandle(hFile);
    }
    
    // Fallback: через FindFirstFile
    WIN32_FIND_DATAW fd;
    HANDLE hFind = FindFirstFileW(fullPath, &fd);
    if (hFind != INVALID_HANDLE_VALUE) {
        ULARGE_INTEGER li;
        li.HighPart = fd.nFileSizeHigh;
        li.LowPart = fd.nFileSizeLow;
        FindClose(hFind);
        return li.QuadPart;
    }
    
    return 0;
}

// Исправленная FS_GetFileSizeBytes
static ULONGLONG FS_GetFileSizeBytes(const wchar_t* fullPath) {
    return FS_GetFileSizeBytesCorrect(fullPath);
}

