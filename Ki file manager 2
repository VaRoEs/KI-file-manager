static void ShowFavoritesMenu(HWND h) {
    EnsureFavFile();
    FILE* f = _wfopen(g_favFile, L"rt,ccs=UTF-8");
    MenuItem items[35]; int n = 0;
    items[n++] = (MenuItem){L"[+] Add to Favorites", 3000, TRUE};
    items[n++] = (MenuItem){L"----------------", 0, FALSE};

    wchar_t paths[30][MAX_PATH] = {0};
    int pathCount = 0;

    if (f) {
        wchar_t line[1024];
        while (fgetws(line, 1024, f) && n < 32) {
            wchar_t* p1 = wcsstr(line, L"--");
            if (!p1) continue;
            *p1 = 0;
            wchar_t* pPath = p1 + 2;
            wchar_t* p2 = wcsstr(pPath, L"--");
            if (p2) *p2 = 0;

            wchar_t* name = line;
            TrimInPlaceW(name); TrimInPlaceW(pPath);

            if (name[0] && pPath[0]) {
                wchar_t* label = (wchar_t*)LocalAlloc(LMEM_FIXED, 256*sizeof(wchar_t));
                lstrcpynW(label, name, 63);
                items[n++] = (MenuItem){label, 3001 + pathCount, TRUE};
                lstrcpynW(paths[pathCount], pPath, MAX_PATH-1);
                pathCount++;
            }
        }
        fclose(f);
    }

    POINT pt; GetCursorPos(&pt);
    UINT sel = ShowMacMenu(h, pt, items, n);

    for (int i=2; i<n; i++) LocalFree((void*)items[i].text);

    if (sel == 3000) {
        HWND fw = GetForegroundWindow();
        wchar_t cls[64]; GetClassNameW(fw, cls, 63);
        if (lstrcmpW(cls, kWndClass) != 0) fw = NULL;

        if (fw) {
            WindowCtx* c = Ctx(fw);
            wchar_t curPath[MAX_PATH] = L"";
            wchar_t curName[64] = L"";
            if (c && c->rootId >= 0 && c->items[c->rootId].fromFS) {
                lstrcpynW(curPath, c->items[c->rootId].path, MAX_PATH);
                lstrcpynW(curName, c->items[c->rootId].name, 63);
            } else if (c->fsRootPath[0] && lstrcmpW(c->fsRootPath, L":Computer:")!=0 && lstrcmpW(c->fsRootPath, L":Search:")!=0) {
                lstrcpynW(curPath, c->fsRootPath, MAX_PATH);
                const wchar_t* sl = wcsrchr(curPath, L'\\');
                if (sl && *(sl+1)) lstrcpynW(curName, sl+1, 63);
                else lstrcpynW(curName, curPath, 63);
            }

            if (curPath[0]) {
                FILE* fa = _wfopen(g_favFile, L"at,ccs=UTF-8");
                if (fa) {
                    fwprintf(fa, L"%s --%s--\n", curName, curPath);
                    fclose(fa);
                }
            }
        }
    } else if (sel > 3000) {
        int idx = sel - 3001;
        wchar_t* p = paths[idx];
        DWORD attr = GetFileAttributesW(p);
        if (attr != INVALID_FILE_ATTRIBUTES && (attr & FILE_ATTRIBUTE_DIRECTORY)) {
            int W = S(760), H = S(500);
            int sx = GetSystemMetrics(SM_CXSCREEN);
            int sy = GetSystemMetrics(SM_CYSCREEN);
            int wx = (sx - W) / 2 + (g_windowCount * 20);
            int wy = (sy - H) / 2 + (g_windowCount * 20);
            HWND win = CreateWindowW(kWndClass, L"", WS_POPUP, wx, wy, W, H, NULL, NULL, g_hInst, p);
            if (win) {
                ShowWindow(win, SW_SHOWDEFAULT);
                UpdateWindow(win);
            }
        }
    }
}

static const wchar_t* wcsistr(const wchar_t* hay, const wchar_t* needle) {
    if (!hay || !needle || !*needle) return hay; 
    size_t nlen = lstrlenW(needle);
    for (const wchar_t* p=hay; *p; ++p) { if (towlower(*p) == towlower(*needle)) { size_t i=1; for (; i<nlen && p[i]; ++i) if (towlower(p[i]) != towlower(needle[i])) break; if (i==nlen) return p; } } return NULL;
}

static void TokenizeQuery(const wchar_t* q, SearchQuery* sq) {
    if (sq->tokens) {
        for (int i = 0; i < sq->tokenCount; i++) {
            if (sq->tokens[i]) HeapFree(GetProcessHeap(), 0, sq->tokens[i]);
        }
        HeapFree(GetProcessHeap(), 0, sq->tokens);
        sq->tokens = NULL;
    }
    sq->tokenCount = 0;
    
    if (!q || !*q) return;
    
    wchar_t lowerQ[512] = {0};
    lstrcpynW(lowerQ, q, 511);
    CharLowerW(lowerQ);
    
    wchar_t* copy = (wchar_t*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, (wcslen(lowerQ) + 1) * sizeof(wchar_t));
    if (!copy) return;
    wcscpy(copy, lowerQ);
    
    wchar_t* ctx = NULL;
    wchar_t* token = wcstok(copy, L" ", &ctx);
    int tokCap = 16;
    sq->tokens = (wchar_t**)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, tokCap * sizeof(wchar_t*));
    
    while (token) {
        if (sq->tokenCount >= tokCap) {
            tokCap *= 2;
            sq->tokens = (wchar_t**)HeapReAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, sq->tokens, tokCap * sizeof(wchar_t*));
        }
        size_t len = wcslen(token);
        sq->tokens[sq->tokenCount] = (wchar_t*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, (len + 1) * sizeof(wchar_t));
        if (sq->tokens[sq->tokenCount]) {
            wcscpy(sq->tokens[sq->tokenCount], token);
            sq->tokenCount++;
        }
        token = wcstok(NULL, L" ", &ctx);
    }
    
    HeapFree(GetProcessHeap(), 0, copy);
}

static void ParseQuery(const wchar_t* q, SearchQuery* sq) {
    memset(sq, 0, sizeof(SearchQuery)); 
    lstrcpyW(sq->pattern, L"*"); 
    sq->topSort = -1;
    sq->tokens = NULL;
    sq->tokenCount = 0;
    
    wchar_t lq[512] = {0}; 
    lstrcpynW(lq, q, 511); 
    CharLowerW(lq);
    
    const wchar_t* pFindAll = wcsstr(lq, L"-findall"); 
    if (!pFindAll) pFindAll = wcsstr(lq, L"findall");

    if (pFindAll) {
        sq->isAdvanced = TRUE; 
        pFindAll += (pFindAll[0] == L'-') ? 8 : 7; 
        while (*pFindAll == L' ' || *pFindAll == L'(') pFindAll++;
        int i = 0; 
        while (*pFindAll && *pFindAll != L')' && i < 126) { 
            sq->pattern[i++] = (*pFindAll == L'@') ? L'*' : *pFindAll; 
            pFindAll++; 
        }
        while (i > 0 && sq->pattern[i-1] == L' ') i--;
        sq->pattern[i] = 0; 
        if (i == 0) lstrcpyW(sq->pattern, L"*");
    } else {
        int i = 0; 
        for (; q[i] && i < 126; i++) sq->pattern[i] = (q[i] == L'@') ? L'*' : q[i]; 
        sq->pattern[i] = 0; 
    }

    for (const wchar_t* p = lq; *p; p++) {
        if ((*p == L'+' || *p == L'-') && p[1] >= L'0' && p[1] <= L'9') {
            sq->isAdvanced = TRUE; 
            sq->hasSizeFilter = TRUE; 
            sq->sizeSign = (*p == L'+') ? 1 : -1; 
            p++; 
            ULONGLONG val = 0;
            while (*p >= L'0' && *p <= L'9') { 
                val = val * 10 + (*p - L'0'); 
                p++; 
            } 
            while (*p == L' ') p++;
            if (wcsncmp(p, L"gb", 2) == 0) val *= 1024ULL * 1024ULL * 1024ULL; 
            else if (wcsncmp(p, L"mb", 2) == 0) val *= 1024ULL * 1024ULL; 
            else if (wcsncmp(p, L"kb", 2) == 0) val *= 1024ULL;
            sq->sizeLimit = val; 
            break;
        }
    }
}

static int CompareSearchItems(const void* a, const void* b) {
    SearchResultItem* itemA = (SearchResultItem*)a; SearchResultItem* itemB = (SearchResultItem*)b;
    if (itemA->size < itemB->size) return (g_topSortDir == 1) ? -1 : 1;
    if (itemA->size > itemB->size) return (g_topSortDir == 1) ? 1 : -1;
    return 0;
}

static DWORD WINAPI SearchThread(LPVOID lpParam) {
    SearchTask* task = (SearchTask*)lpParam;
    
    int resultCapacity = 10000;
    SearchResultItem* pResults = (SearchResultItem*)HeapAlloc(GetProcessHeap(), HEAP_ZERO_MEMORY, sizeof(SearchResultItem) * resultCapacity);
    int count = 0;
    
    if (!task->sq.isAdvanced && task->sq.pattern[0] && lstrcmpW(task->sq.pattern, L"*") != 0) {
        TokenizeQuery(task->sq.pattern, &task->sq);
    }
    
    LoadIndexCache();
    
    if (g_indexCacheLoaded && g_indexCache) {
        SearchInIndex(&task->sq, &pResults, &resultCapacity, &count);
    }
    
    if (g_hCancelEvent && WaitForSingleObject(g_hCancelEvent, 0) != WAIT_OBJECT_0) {
        if (lstrcmpW(task->startDir, L"ALL") == 0) {
            wchar_t drives[256] = {0}; 
            DWORD r = GetLogicalDriveStringsW(255, drives);
            if (r > 0) {
                wchar_t* p = drives;
                while (*p && g_hCancelEvent && WaitForSingleObject(g_hCancelEvent, 0) != WAIT_OBJECT_0) {
                    wchar_t rootDir[16] = {0}; 
                    lstrcpynW(rootDir, p, 15); 
                    UINT type = GetDriveTypeW(rootDir);
                    if (type == DRIVE_FIXED || type == DRIVE_REMOVABLE || type == DRIVE_RAMDISK) {
                        int mftAdded = ScanDriveViaMFT(rootDir, &task->sq, &pResults, &resultCapacity, &count, g_hCancelEvent);
                        if (mftAdded == 0) {
                            CollectMissingFiles(rootDir, &task->sq, &pResults, &resultCapacity, &count);
                        }
                    }
                    p += lstrlenW(p) + 1;
                }
            }
        } else { 
            CollectMissingFiles(task->startDir, &task->sq, &pResults, &resultCapacity, &count);
        }
    }
    
    if (task->sq.isTop && count > 0) { 
        g_topSortDir = task->sq.topSort; 
        qsort(pResults, count, sizeof(SearchResultItem), CompareSearchItems); 
        if (task->sq.topCount > 0 && count > task->sq.topCount) { 
            count = task->sq.topCount; 
        } 
    }
    
    if (task->sq.tokens) {
        for (int i = 0; i < task->sq.tokenCount; i++) {
            if (task->sq.tokens[i]) HeapFree(GetProcessHeap(), 0, task->sq.tokens[i]);
        }
        HeapFree(GetProcessHeap(), 0, task->sq.tokens);
        task->sq.tokens = NULL;
    }
    
    for (int i=0; i<MAX_CONCURRENT_OPS; i++) {
        if (g_progData[i].isRunning && g_progData[i].opType == 999) {
            g_progData[i].isRunning = FALSE;
        }
    }

    PostMessageW(task->hwndNotify, WM_APP+5, (WPARAM)pResults, (LPARAM)count); 
    HeapFree(GetProcessHeap(), 0, task);
    return 0;
}

static void IndexDirectoryRecursive(FILE* f, const wchar_t* dir, volatile BOOL* pRunning) {
    if (!*pRunning) return;
    
    wchar_t mask[MAX_PATH] = {0};
    _snwprintf(mask, MAX_PATH-1, L"%s\\*", dir);
    mask[MAX_PATH-1] = 0;
    
    WIN32_FIND_DATAW fd;
    HANDLE hFind = FindFirstFileW(mask, &fd);
    if (hFind == INVALID_HANDLE_VALUE) return;
    
    do {
        if (!*pRunning) break;
        
        if (lstrcmpW(fd.cFileName, L".") == 0 || lstrcmpW(fd.cFileName, L"..") == 0) continue;
        
        wchar_t fullPath[MAX_PATH] = {0};
        _snwprintf(fullPath, MAX_PATH-1, L"%s\\%s", dir, fd.cFileName);
        fullPath[MAX_PATH-1] = 0;
        
        if (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) {
            IndexDirectoryRecursive(f, fullPath, pRunning);
        } else {
            ULARGE_INTEGER li;
            li.HighPart = fd.nFileSizeHigh;
            li.LowPart = fd.nFileSizeLow;
            fwprintf(f, L"%s | %s | %llu\n", fd.cFileName, fullPath, (unsigned long long)li.QuadPart);
            g_indexedFiles++;
        }
    } while (FindNextFileW(hFind, &fd) && *pRunning);
    
    FindClose(hFind);
}

static DWORD WINAPI IndexingThread(LPVOID lpParam) {
    HWND hMain = (HWND)lpParam;
    EnsureIndexFile();
    g_isIndexing = TRUE;
    g_indexedFiles = 0;
    
    FILE* f = _wfopen(g_indexFile, L"wt,ccs=UTF-8");
    if (!f) { 
        g_isIndexing = FALSE; 
        return 0; 
    }
    
    fwprintf(f, L"// KI Index File - Full Recursive Scan\n");
    fwprintf(f, L"// Format: FileName | FullPath | SizeInBytes\n\n");
    
    wchar_t drives[256] = {0};
    DWORD r = GetLogicalDriveStringsW(255, drives);
    if (r > 0) {
        wchar_t* p = drives;
        while (*p && g_isIndexing) {
            wchar_t rootDir[16] = {0}; 
            lstrcpynW(rootDir, p, 15);
            
            UINT type = GetDriveTypeW(rootDir);
            if (type == DRIVE_FIXED || type == DRIVE_REMOVABLE || type == DRIVE_RAMDISK) {
                IndexDirectoryRecursive(f, rootDir, &g_isIndexing);
            }
            p += lstrlenW(p) + 1;
        }
    }
    
    wchar_t summary[128] = {0};
    _snwprintf(summary, 127, L"\n// Total files indexed: %llu\n", (unsigned long long)g_indexedFiles);
    fwprintf(f, summary);
    
    fclose(f);
    g_isIndexing = FALSE;
    
    LoadIndexCache();
    
    if (g_indexCacheLoaded && g_indexCache && g_stringArena) {
        SaveIndexCacheBinary();
    }
    
    PostMessageW(hMain, WM_APP+2, 0, 0);
    return 0;
}

static BOOL GetDesktopPath(wchar_t* outPath) {
    PWSTR p = NULL; HRESULT hr = SHGetKnownFolderPath(&FOLDERID_Desktop, 0, NULL, &p);
    if (SUCCEEDED(hr) && p) { lstrcpynW(outPath, p, MAX_PATH-1); CoTaskMemFree(p); return TRUE; }
    wchar_t up[MAX_PATH] = {0}; DWORD n = GetEnvironmentVariableW(L"USERPROFILE", up, MAX_PATH);
    if (n>0 && n<MAX_PATH) { lstrcpynW(outPath, up, MAX_PATH-1); if (outPath[lstrlenW(outPath)-1] != L'\\') lstrcatW(outPath, L"\\Desktop"); else lstrcatW(outPath, L"Desktop"); return TRUE; }
    lstrcpynW(outPath, L"C:\\", MAX_PATH-1); return FALSE;
}

