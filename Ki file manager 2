                int cx = startCx; int cy = startCy; if (g_topBar) { cx += (int)((ptTrash.x - startCx) * t); cy += (int)((ptTrash.y - startCy) * t); }
                int dw = (int)((L->iconSize + S(8) + L->labelH) * scale); int dh = (int)((L->iconSize + S(8) + L->labelH) * scale); 
                DrawItemSprite(dc, L, &c->items[i], cx - dw/2, cy - dh/2, dw, dh, alpha); 
