            HPEN pR = CreatePen(PS_SOLID, S(1), RGB(255,255,255)); HGDIOBJ op = SelectObject(dc, pR);
            RoundRect(dc, br.left, br.top, br.right, br.bottom, S(12), S(12));
            HFONT fBadge = NULL; PickClassicFont(&fBadge, 14, TRUE); HGDIOBJ of = SelectObject(dc, fBadge);
            SetTextColor(dc, RGB(255,255,255)); SetBkMode(dc, TRANSPARENT);
            DrawTextW(dc, badge, -1, &br, DT_CENTER|DT_VCENTER|DT_SINGLELINE);
            SelectObject(dc, of); DeleteObject(fBadge); SelectObject(dc, op); DeleteObject(pR); SelectObject(dc, ob); DeleteObject(bgR);
        }
    }
    if (c->moveAnimActive && c->moveDstIdx>=0) {
        RECT rDstI, rDstL; ItemPixelRect(L, c, &c->items[c->moveDstIdx], &rDstI, &rDstL); float scale = 1.0f - 0.6f * c->moveStep; BYTE alpha = (BYTE)(255 * (1.0f - c->moveStep));
