static DWORD WINAPI BackgroundScannerThread(LPVOID lpParam) {
    HWND hwnd = (HWND)lpParam;
    while (TRUE) {
        BOOL updated = FALSE;
        WindowCtx* c = Ctx(hwnd);
        if (c && c->items) {
            for (int i = 0; i < c->itemCount; i++) {
                if (!c->items[i].scanned && c->items[i].fromFS) {
                    if (c->items[i].type == IT_FOLDER) {
                        ULONGLONG total = 0;
                        FS_GetDirSizeRecursive(c->items[i].path, &total);
                        c->items[i].sizeCache = total;
                    }
                    c->items[i].scanned = TRUE; c->items[i].scanProgress = 1.0f; updated = TRUE;
                }
            }
        }
        if (updated) {
            PostMessageW(hwnd, WM_APP+15, 0, 0); 
        }
        Sleep(200); 
    }
    return 0;
}

