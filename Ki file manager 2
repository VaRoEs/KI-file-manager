        if (tip.right > cr.right - S(6)) { int dx = tip.right - (cr.right - S(6)); OffsetRect(&tip, -dx, 0); } if (tip.bottom > cr.bottom - S(6)) { int dy = tip.bottom - (cr.bottom - S(6)); OffsetRect(&tip, 0, -dy); }
        wchar_t title[256], body[256]; lstrcpynW(title, it->name[0] ? it->name : L"(без имени)", 255); if (it->desc[0]) lstrcpynW(body, it->desc, 255); else lstrcpynW(body, it->path[0]?it->path:L"(нет пути)", 255); DrawTooltipSmall(dc, tip, title, body);
    }
