static void SaveIndexCacheBinary(void) {
    if (!g_indexCacheLoaded || !g_indexCache || !g_stringArena) return;
    
    wchar_t binFile[MAX_PATH] = {0};
    lstrcpynW(binFile, g_indexFile, MAX_PATH);
    wchar_t* dot = wcsrchr(binFile, L'.');
    if (dot) lstrcpyW(dot, L".bin");
    else lstrcatW(binFile, L".bin");
    
    HANDLE hFile = CreateFileW(binFile, GENERIC_WRITE, 0, NULL, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hFile != INVALID_HANDLE_VALUE) {
        DWORD written;
        WriteFile(hFile, &g_indexCacheCount, sizeof(int), &written, NULL);
        
        size_t arenaSizeChars = g_arenaOffset;
        WriteFile(hFile, &arenaSizeChars, sizeof(size_t), &written, NULL);
        
        WriteFile(hFile, g_stringArena, (DWORD)(arenaSizeChars * sizeof(wchar_t)), &written, NULL);
        
        for (int i = 0; i < g_indexCacheCount; i++) {
            size_t nameOffset = (g_indexCache[i].name) ? (g_indexCache[i].name - g_stringArena) : 0;
            size_t pathOffset = (g_indexCache[i].path) ? (g_indexCache[i].path - g_stringArena) : 0;
            WriteFile(hFile, &nameOffset, sizeof(size_t), &written, NULL);
            WriteFile(hFile, &pathOffset, sizeof(size_t), &written, NULL);
            WriteFile(hFile, &g_indexCache[i].size, sizeof(ULONGLONG), &written, NULL);
            WriteFile(hFile, &g_indexCache[i].inIndex, sizeof(BOOL), &written, NULL);
        }
        CloseHandle(hFile);
    }
}

static BOOL MatchesTokens(const wchar_t* name, SearchQuery* sq) {
    if (!sq->pattern[0] || lstrcmpW(sq->pattern, L"*") == 0) return TRUE;
    wchar_t lowerName[MAX_PATH] = {0};
    wchar_t lowerPattern[MAX_PATH] = {0};
    lstrcpynW(lowerName, name, MAX_PATH);
    lstrcpynW(lowerPattern, sq->pattern, MAX_PATH);
    CharLowerW(lowerName);
    CharLowerW(lowerPattern);
    return (wcsstr(lowerName, lowerPattern) != NULL);
}

static int SearchInIndex(SearchQuery* sq, SearchResultItem** ppResults, int* pCapacity, int* pCount) {
    EnterCriticalSection(&g_indexCs);
    
    if (!g_indexCacheLoaded || !g_indexCache) {
        LeaveCriticalSection(&g_indexCs);
        return 0;
    }
    
    for (int i = 0; i < g_indexCacheCount; i++) {
        IndexEntry* entry = &g_indexCache[i];
        if (!entry->name || !entry->path) continue;
        
        BOOL match = TRUE;
        
        if (sq->pattern[0] && lstrcmpW(sq->pattern, L"*") != 0) {
            if (sq->isAdvanced) {
                if (!PathMatchSpecW(entry->name, sq->pattern)) match = FALSE;
            } else {
                wchar_t lowerName[MAX_PATH] = {0};
                wchar_t lowerPattern[MAX_PATH] = {0};
                lstrcpynW(lowerName, entry->name, MAX_PATH);
                lstrcpynW(lowerPattern, sq->pattern, MAX_PATH);
                CharLowerW(lowerName);
                CharLowerW(lowerPattern);
                if (!wcsstr(lowerName, lowerPattern)) match = FALSE;
            }
        }
        
        if (match && sq->hasSizeFilter) {
            if (sq->sizeSign > 0 && entry->size <= sq->sizeLimit) match = FALSE;
            if (sq->sizeSign < 0 && entry->size >= sq->sizeLimit) match = FALSE;
        }
        
        if (match) {
            if (*pCount >= *pCapacity) {
                *ppResults = (SearchResultItem*)DynGrow(*ppResults, pCapacity, pCount, sizeof(SearchResultItem));
                if (!*ppResults) {
                    LeaveCriticalSection(&g_indexCs);
                    return *pCount;
                }
            }
            lstrcpynW((*ppResults)[*pCount].name, entry->name, MAX_PATH);
            lstrcpynW((*ppResults)[*pCount].path, entry->path, MAX_PATH);
            (*ppResults)[*pCount].size = entry->size;
            (*ppResults)[*pCount].isDir = FALSE;
            DWORD attrs = GetFileAttributesW(entry->path);
            if (attrs != INVALID_FILE_ATTRIBUTES && (attrs & FILE_ATTRIBUTE_DIRECTORY)) {
                (*ppResults)[*pCount].isDir = TRUE;
            }
            (*pCount)++;
        }
    }
    
    LeaveCriticalSection(&g_indexCs);
    return *pCount;
}

static int CollectMissingFiles(const wchar_t* dir, SearchQuery* sq, SearchResultItem** ppResults, 
                                int* pCapacity, int* pCount) {
    if (g_hCancelEvent && WaitForSingleObject(g_hCancelEvent, 0) == WAIT_OBJECT_0) return 0;
    
    wchar_t mask[MAX_PATH] = {0};
    if (dir[lstrlenW(dir)-1] == L'\\')
        _snwprintf(mask, MAX_PATH-1, L"%s*", dir);
    else
        _snwprintf(mask, MAX_PATH-1, L"%s\\*", dir);
    
    WIN32_FIND_DATAW fd;
    HANDLE h = FindFirstFileW(mask, &fd);
    if (h == INVALID_HANDLE_VALUE) return 0;
    
    int addedCount = 0;
    do {
        if (g_hCancelEvent && WaitForSingleObject(g_hCancelEvent, 0) == WAIT_OBJECT_0) break;
        if (lstrcmpW(fd.cFileName, L".") == 0 || lstrcmpW(fd.cFileName, L"..") == 0) continue;
        
        wchar_t full[MAX_PATH] = {0};
        if (dir[lstrlenW(dir)-1] == L'\\')
            _snwprintf(full, MAX_PATH-1, L"%s%s", dir, fd.cFileName);
        else
            _snwprintf(full, MAX_PATH-1, L"%s\\%s", dir, fd.cFileName);
        
        BOOL isDir = (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0;
        
        IndexEntry key;
        wchar_t keyPath[MAX_PATH] = {0};
        lstrcpynW(keyPath, full, MAX_PATH);
        key.path = keyPath;
        key.name = NULL;
        BOOL inIndex = FALSE;
        
        EnterCriticalSection(&g_indexCs);
        if (g_indexCacheLoaded && g_indexCache && g_indexCacheCount > 0) {
            IndexEntry* found = (IndexEntry*)bsearch(&key, g_indexCache, g_indexCacheCount, sizeof(IndexEntry), IndexEntryCompare);
            inIndex = (found != NULL);
        }
        LeaveCriticalSection(&g_indexCs);
        
        if (!inIndex) {
            BOOL match = TRUE;
            if (sq->pattern[0] && lstrcmpW(sq->pattern, L"*") != 0) {
                if (sq->isAdvanced) {
                    if (!PathMatchSpecW(fd.cFileName, sq->pattern)) match = FALSE;
                } else {
                    if (!MatchesTokens(fd.cFileName, sq)) match = FALSE;
                }
            }
            
            ULONGLONG sz = 0;
            if (!isDir) {
                ULARGE_INTEGER li;
                li.HighPart = fd.nFileSizeHigh;
                li.LowPart = fd.nFileSizeLow;
                sz = li.QuadPart;
            }
            
            if (match && sq->hasSizeFilter && !isDir) {
                if (sq->sizeSign > 0 && sz <= sq->sizeLimit) match = FALSE;
                if (sq->sizeSign < 0 && sz >= sq->sizeLimit) match = FALSE;
            }
            
            if (match) {
                if (*pCount >= *pCapacity) {
                    *ppResults = (SearchResultItem*)DynGrow(*ppResults, pCapacity, pCount, sizeof(SearchResultItem));
                    if (!*ppResults) break;
                }
                
                (*ppResults)[*pCount].size = sz;
                (*ppResults)[*pCount].isDir = isDir;
                lstrcpynW((*ppResults)[*pCount].name, fd.cFileName, MAX_PATH);
                lstrcpynW((*ppResults)[*pCount].path, full, MAX_PATH);
                (*pCount)++;
                addedCount++;
            }
        }
        
        if (isDir) {
            CollectMissingFiles(full, sq, ppResults, pCapacity, pCount);
        }
        
    } while (FindNextFileW(h, &fd) && (g_hCancelEvent && WaitForSingleObject(g_hCancelEvent, 0) != WAIT_OBJECT_0));
    
    FindClose(h);
    return addedCount;
}

static int ScanDriveViaMFT(const wchar_t* rootPath, SearchQuery* sq, SearchResultItem** ppResults, int* pCapacity, int* pCount, HANDLE hCancel) {
    if (hCancel && WaitForSingleObject(hCancel, 0) == WAIT_OBJECT_0) return 0;
    
    wchar_t volumePath[64] = {0};
    _snwprintf(volumePath, 63, L"\\\\.\\%c:", rootPath[0]);
    
    HANDLE hVolume = CreateFileW(volumePath, GENERIC_READ, FILE_SHARE_READ | FILE_SHARE_WRITE, 
                                  NULL, OPEN_EXISTING, FILE_FLAG_BACKUP_SEMANTICS, NULL);
    if (hVolume == INVALID_HANDLE_VALUE) return 0;
    
    int addedCount = 0;
    
    MFT_ENUM_DATA med;
    memset(&med, 0, sizeof(med));
    med.StartFileReferenceNumber = 0;
    med.LowUsn = 0;
    med.HighUsn = 0x7FFFFFFFFFFFFFFFULL;
    
    BYTE buffer[65536];
    DWORD bytesReturned;
    
    while (DeviceIoControl(hVolume, FSCTL_ENUM_USN_DATA, &med, sizeof(med), 
                           buffer, sizeof(buffer), &bytesReturned, NULL) && bytesReturned > sizeof(DWORDLONG)) {
        if (hCancel && WaitForSingleObject(hCancel, 0) == WAIT_OBJECT_0) break;
        
        DWORDLONG nextUsn = *((DWORDLONG*)buffer);
        USN_RECORD* pRecord = (USN_RECORD*)(buffer + sizeof(DWORDLONG));
        USN_RECORD* pEnd = (USN_RECORD*)(buffer + bytesReturned);
        
        while (pRecord < pEnd && (!hCancel || WaitForSingleObject(hCancel, 0) != WAIT_OBJECT_0)) {
            if (pRecord->RecordLength == 0) break;
            
            if (pRecord->FileNameLength > 0) {
                wchar_t fileName[MAX_PATH] = {0};
                int nameLen = pRecord->FileNameLength / sizeof(wchar_t);
                if (nameLen > 0 && nameLen < MAX_PATH - 1) {
                    memcpy(fileName, pRecord->FileName, pRecord->FileNameLength);
                    fileName[nameLen] = 0;
                    
                    if (lstrcmpW(fileName, L".") != 0 && lstrcmpW(fileName, L"..") != 0) {
                        wchar_t fullPath[MAX_PATH] = {0};
                        _snwprintf(fullPath, MAX_PATH-1, L"%s%s", rootPath, fileName);
                        
                        IndexEntry key;
                        wchar_t keyPath[MAX_PATH] = {0};
                        lstrcpynW(keyPath, fullPath, MAX_PATH);
                        key.path = keyPath;
                        key.name = NULL;
                        BOOL inIndex = FALSE;
                        
                        EnterCriticalSection(&g_indexCs);
                        if (g_indexCacheLoaded && g_indexCache && g_indexCacheCount > 0) {
                            IndexEntry* found = (IndexEntry*)bsearch(&key, g_indexCache, g_indexCacheCount, sizeof(IndexEntry), IndexEntryCompare);
                            inIndex = (found != NULL);
                        }
                        LeaveCriticalSection(&g_indexCs);
                        
                        if (!inIndex) {
                            BOOL match = TRUE;
                            if (sq->pattern[0] && lstrcmpW(sq->pattern, L"*") != 0) {
                                if (sq->isAdvanced) {
                                    if (!PathMatchSpecW(fileName, sq->pattern)) match = FALSE;
                                } else {
                                    if (!MatchesTokens(fileName, sq)) match = FALSE;
                                }
                            }
                            
                            if (match) {
                                if (*pCount >= *pCapacity) {
                                    *ppResults = (SearchResultItem*)DynGrow(*ppResults, pCapacity, pCount, sizeof(SearchResultItem));
                                    if (!*ppResults) break;
                                }
                                
                                (*ppResults)[*pCount].size = 0;
                                (*ppResults)[*pCount].isDir = (pRecord->FileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0;
                                lstrcpynW((*ppResults)[*pCount].name, fileName, MAX_PATH);
                                lstrcpynW((*ppResults)[*pCount].path, fullPath, MAX_PATH);
                                (*pCount)++;
                                addedCount++;
                            }
                        }
                    }
                }
            }
            pRecord = (USN_RECORD*)((BYTE*)pRecord + pRecord->RecordLength);
        }
        
        med.StartFileReferenceNumber = nextUsn;
    }
    
    CloseHandle(hVolume);
    return addedCount;
}

