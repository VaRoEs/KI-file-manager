static DWORD WINAPI FileOpWorker(LPVOID lpParam) {
    ProgressData* pd = (ProgressData*)lpParam;
    CoInitializeEx(NULL, COINIT_APARTMENTTHREADED);

    IFileOperation *pfo = NULL;
    HRESULT hr = CoCreateInstance(&CLSID_FileOperation, NULL, CLSCTX_ALL, &IID_IFileOperation, (void**)&pfo);
    
    if (SUCCEEDED(hr) && pfo) {
        pfo->lpVtbl->SetOperationFlags(pfo, FOF_NOCONFIRMATION | FOF_SILENT | 
                                        FOFX_SHOWELEVATIONPROMPT | FOFX_RECYCLEONDELETE |
                                        FOF_NOCONFIRMMKDIR | FOF_RENAMEONCOLLISION);

        CustomSink sink = { &g_sinkVtbl, pd };
        DWORD dwCookie = 0;
        pfo->lpVtbl->Advise(pfo, (IFileOperationProgressSink*)&sink, &dwCookie);

        IShellItem *psiDest = NULL;
        if (pd->opType != FO_DELETE && pd->destDir[0]) {
            SHCreateItemFromParsingName(pd->destDir, NULL, &IID_IShellItem, (void**)&psiDest);
        }

        for (const wchar_t* p = pd->multiSrc; *p; p += lstrlenW(p) + 1) {
            if (!pd->isRunning) break;
            
            IShellItem *psiItem = NULL;
            if (SUCCEEDED(SHCreateItemFromParsingName(p, NULL, &IID_IShellItem, (void**)&psiItem))) {
                if (pd->opType == FO_DELETE) {
                    pfo->lpVtbl->DeleteItem(pfo, psiItem, NULL);
                } else if (pd->opType == FO_COPY) {
                    pfo->lpVtbl->CopyItem(pfo, psiItem, psiDest, NULL, NULL);
                } else if (pd->opType == FO_MOVE) {
                    pfo->lpVtbl->MoveItem(pfo, psiItem, psiDest, NULL, NULL);
                }
                psiItem->lpVtbl->Release(psiItem);
            }
        }

        if (pd->isRunning) {
            hr = pfo->lpVtbl->PerformOperations(pfo);
        }

        if (psiDest) psiDest->lpVtbl->Release(psiDest);
        pfo->lpVtbl->Unadvise(pfo, dwCookie);
        pfo->lpVtbl->Release(pfo);
    }

    pd->isRunning = FALSE;
    
    if (pd->hProgWnd) {
        PostMessageW(pd->hProgWnd, WM_CLOSE, 0, 0);
    }
    
    CoUninitialize();
    return 0;
}

static void StartFileOperation(int opType, const wchar_t* multiSrc, const wchar_t* destDir, HWND hParent) {
    int slot = -1;
    for (int i = 0; i < MAX_CONCURRENT_OPS; i++) { 
        if (!g_progData[i].isRunning) { 
            slot = i; 
            break; 
        } 
    }
    if (slot == -1) { 
        MessageBoxW(hParent, L"Max parallel operations (5) reached!", L"Busy", MB_OK); 
        return; 
    }

    ProgressData* pd = &g_progData[slot];
    pd->opType = opType;
    pd->isRunning = TRUE;
    pd->slotIdx = slot;
    pd->totalBytes = 0;
    pd->bytesTransferred = 0;
    
    if (pd->multiSrc) { 
        LocalFree(pd->multiSrc); 
        pd->multiSrc = NULL; 
    }
    
    if (multiSrc) {
        size_t srcBytes = 2;
        for (const wchar_t* p = multiSrc; *p; p += lstrlenW(p) + 1) {
            srcBytes += lstrlenW(p) + 1;
        }
        pd->multiSrc = (wchar_t*)LocalAlloc(LMEM_FIXED, srcBytes * sizeof(wchar_t));
        if (pd->multiSrc && multiSrc) {
            memcpy(pd->multiSrc, multiSrc, srcBytes * sizeof(wchar_t));
        }
    }

    if (destDir) {
        lstrcpyW(pd->destDir, destDir);
    } else {
        pd->destDir[0] = 0;
    }
    
    RECT wr;
    GetWindowRect(hParent, &wr);
    
    const wchar_t* opTitle = L"File Operation";
    if (opType == FO_COPY) opTitle = L"Copying...";
    else if (opType == FO_MOVE) opTitle = L"Moving...";
    else if (opType == FO_DELETE) opTitle = L"Deleting...";
    else if (opType == 999) opTitle = L"Searching...";
    
    pd->hProgWnd = CreateWindowExW(
        WS_EX_TOOLWINDOW | WS_EX_TOPMOST, 
        kProgClass, 
        opTitle, 
        WS_POPUP,
        wr.left + S(100) + slot * S(30), 
        wr.top + S(150) + slot * S(30), 
        S(320), 
        S(100), 
        hParent, 
        NULL, 
        g_hInst, 
        pd
    );
    
    if (pd->hProgWnd) {
        ShowWindow(pd->hProgWnd, SW_SHOWNOACTIVATE);
        UpdateWindow(pd->hProgWnd);
    }
    
    if (opType != 999) {
        pd->hThread = CreateThread(NULL, 0, FileOpWorker, pd, 0, NULL);
    }
}

static LRESULT CALLBACK ProgressProc(HWND w, UINT m, WPARAM wp, LPARAM lp) {
    ProgressData* pd = (ProgressData*)GetWindowLongPtrW(w, GWLP_USERDATA);
    switch(m) {
        case WM_CREATE: {
            CREATESTRUCT* cs = (CREATESTRUCT*)lp;
            pd = (ProgressData*)cs->lpCreateParams;
            SetWindowLongPtrW(w, GWLP_USERDATA, (LONG_PTR)pd);
            SetTimer(w, 1, 50, NULL);
        } return 0;
        
        case WM_TIMER: {
            if (pd && !pd->isRunning) {
                KillTimer(w, 1);
                DestroyWindow(w);
            } else {
                InvalidateRect(w, NULL, FALSE);
            }
        } return 0;
        
        case WM_PAINT: {
            PAINTSTRUCT ps; 
            HDC dc = BeginPaint(w, &ps); 
            RECT r; 
            GetClientRect(w, &r);
            
            HBRUSH bg = CreateSolidBrush(RGB(245, 245, 245));
            FillRect(dc, &r, bg);
            DeleteObject(bg);
            
            DrawClassicBezel(dc, r);
            
            RECT titleR = r;
            titleR.bottom = titleR.top + S(26); // Чуть уже шапка для компактности
            DrawPinstripe(dc, titleR);
            
            HFONT fTitle;
            PickClassicFont(&fTitle, 13, TRUE);
            HGDIOBJ of = SelectObject(dc, fTitle);
            SetBkMode(dc, TRANSPARENT);
            
            const wchar_t* opText = L"File Operation";
            if (pd) {
                if (pd->opType == FO_COPY) opText = L"Copying files...";
                else if (pd->opType == FO_MOVE) opText = L"Moving files...";
                else if (pd->opType == FO_DELETE) opText = L"Deleting files...";
                else if (pd->opType == 999) opText = L"Searching...";
            }
            
            // Выравниваем заголовок строго по центру шапки
            TextOutAlign(dc, (titleR.left + titleR.right) / 2, titleR.top + S(5), opText, TA_TOP | TA_CENTER);
            SelectObject(dc, of);
            DeleteObject(fTitle);
            
            double pct = 0.0;
            if (pd && pd->opType != 999 && pd->totalBytes > 0) {
                pct = (double)pd->bytesTransferred / (double)pd->totalBytes;
                if (pct > 1.0) pct = 1.0;
            } else if (pd && pd->opType == 999) {
                static int bounce = 0;
                bounce = (bounce + 2) % 100;
                pct = bounce / 100.0;
            }
            
            // Выравниваем саму полосу прогресса по центру окна
            int barHeight = S(16);
            RECT barR = { 
                r.left + S(20), 
                titleR.bottom + S(20), 
                r.right - S(20), 
                titleR.bottom + S(20) + barHeight 
            };
            
            HPEN pen = CreatePen(PS_SOLID, 1, RGB(100, 100, 100));
            HBRUSH bgBar = CreateSolidBrush(RGB(230, 230, 230));
            HGDIOBJ oldP = SelectObject(dc, pen);
            HGDIOBJ oldB = SelectObject(dc, bgBar);
            RoundRect(dc, barR.left, barR.top, barR.right, barR.bottom, S(4), S(4)); // Менее круглые края для строгости
            SelectObject(dc, oldB);
            DeleteObject(bgBar);
            
            RECT fillR = barR;
            InflateRect(&fillR, -1, -1); // Более точная заливка внутри рамки
            
            if (pct > 0) {
                int fillWidth = (int)((fillR.right - fillR.left) * pct);
                fillR.right = fillR.left + fillWidth;
                
                if (fillR.right > fillR.left) {
                    HBRUSH bfill = CreateSolidBrush(RGB(46, 204, 113));
                    SelectObject(dc, bfill);
                    SelectObject(dc, GetStockObject(NULL_PEN));
                    RoundRect(dc, fillR.left, fillR.top, fillR.right, fillR.bottom, S(2), S(2));
                    DeleteObject(bfill);
                }
            }
            SelectObject(dc, oldP);
            DeleteObject(pen);
            
            HFONT fText;
            PickClassicFont(&fText, 12, FALSE);
            SelectObject(dc, fText);
            
            // Проценты теперь не слипаются с нижней строкой, а рисуются справа или по центру в зависимости от режима
            wchar_t pctStr[32];
            _snwprintf(pctStr, 31, L"%.0f%%", pct * 100.0);
            
            if (pd && pd->opType != 999 && pd->totalBytes > 0) {
                wchar_t status[128], total[64], combined[256];
                FS_FormatSizeDual(pd->bytesTransferred, status, 128);
                FS_FormatSizeDual(pd->totalBytes, total, 64);
                _snwprintf(combined, 255, L"%s / %s", status, total);
                
                // Текст объема данных слева под баром
                TextOutAlign(dc, barR.left, barR.bottom + S(8), combined, TA_TOP | TA_LEFT);
                // Текст процентов справа под баром
                TextOutAlign(dc, barR.right, barR.bottom + S(8), pctStr, TA_TOP | TA_RIGHT);
            } else if (pd && pd->opType == 999) {
                // При поиске центрируем текст
                TextOutAlign(dc, (barR.left + barR.right) / 2, barR.bottom + S(8), L"Scanning drives...", TA_TOP | TA_CENTER);
            }
            
            SelectObject(dc, of);
            DeleteObject(fText);
            
            EndPaint(w, &ps);
        } return 0;
        
        case WM_CLOSE: {
            if (pd && pd->isRunning) {
                pd->isRunning = FALSE;
            }
            DestroyWindow(w);
        } return 0;
    }
    return DefWindowProcW(w, m, wp, lp);
}

static BOOL DoPasteIntoDirViaProgress(HWND owner, const wchar_t* destDir, const wchar_t* textMulti, BOOL isMove) {
    if (!destDir || !*destDir || !textMulti || !*textMulti) return FALSE;
    int maxLines = 16384;
    wchar_t** arr = (wchar_t**)LocalAlloc(LMEM_FIXED, maxLines * sizeof(wchar_t*));
    if (!arr) return FALSE;
    int n = SplitLinesToArray(textMulti, arr, maxLines);
    if (n<=0) { LocalFree(arr); return FALSE; }
    wchar_t* multi = BuildDoubleNullMultiString(arr, n);
    if (!multi) { FreeArray(arr, n); LocalFree(arr); return FALSE; }
    StartFileOperation(isMove ? FO_MOVE : FO_COPY, multi, destDir, owner);
    LocalFree(multi); FreeArray(arr, n); LocalFree(arr); return TRUE;
}

static int GetCustomIconId(const Item* it) {
    if (it->type != IT_FILE) return -1;
    const wchar_t* ext = wcsrchr(it->name, L'.');
    if (ext) {
        wchar_t e[32] = {0}; lstrcpynW(e, ext, 31); CharLowerW(e);
        for (int i = 0; i < g_iconAssocCount; i++) {
            if (lstrcmpW(e, g_iconAssocs[i].ext) == 0) {
                return g_iconAssocs[i].iconId;
            }
        }
    }
    return -1;
}

static void DrawTrashIcon(HDC dc, int x, int y, int size, float lidOpenPct) {
    int w = (int)(size * 0.7f), h = (int)(size * 0.85f);
    int dx = x + (size - w)/2, dy = y + (size - h)/2;
    int s1 = max(1, (int)(size*0.02f)), s2 = max(1, (int)(size*0.04f)), s4 = max(1, (int)(size*0.08f));
    int s6 = max(1, (int)(size*0.1f)), s8 = max(1, (int)(size*0.15f)), s10 = max(1, (int)(size*0.18f));
    int lidDy = dy - (int)(size * 0.4f * lidOpenPct);

    if (g_trashSkin == 1) {
        HPEN pEdge = CreatePen(PS_SOLID, S(2), RGB(100, 120, 140));
        HGDIOBJ oldP = SelectObject(dc, pEdge); 
        HBRUSH nullBr = (HBRUSH)GetStockObject(NULL_BRUSH); HGDIOBJ oldB = SelectObject(dc, nullBr);
        POINT pts[] = { {dx, lidDy}, {dx+w, lidDy}, {dx+w-S(10), dy+h}, {dx+S(10), dy+h} };
        Polygon(dc, pts, 4);
        HPEN pMesh = CreatePen(PS_SOLID, 1, RGB(150, 170, 190)); SelectObject(dc, pMesh);
        for (int yl = dy + S(8); yl < dy + h; yl += S(8)) { MoveToEx(dc, dx + S(2), yl, NULL); LineTo(dc, dx+w - S(2), yl); }
        for (int xl = dx + S(8); xl < dx + w; xl += S(8)) { MoveToEx(dc, xl, dy, NULL); LineTo(dc, xl - S(6), dy+h); }
        SelectObject(dc, oldP); SelectObject(dc, oldB); DeleteObject(pEdge); DeleteObject(pMesh);
        return;
    } 
    
    if (g_trashSkin == 2) {
        HBRUSH bDark = CreateSolidBrush(RGB(50, 50, 50));
        HPEN pEdge = CreatePen(PS_SOLID, S(2), RGB(0, 0, 0));
        HGDIOBJ oldB = SelectObject(dc, bDark); HGDIOBJ oldP = SelectObject(dc, pEdge);
        Rectangle(dc, dx, dy + S(15), dx+w, dy+h);
        HBRUSH bGreen = CreateSolidBrush(RGB(40, 200, 80)); SelectObject(dc, bGreen);
        Rectangle(dc, dx - S(5), lidDy, dx+w + S(5), lidDy + S(10));
        HPEN pLine = CreatePen(PS_SOLID, S(3), RGB(80, 220, 100)); SelectObject(dc, pLine);
        MoveToEx(dc, dx + w/2, dy + S(25), NULL); LineTo(dc, dx + w/2, dy+h - S(10));
        SelectObject(dc, oldB); SelectObject(dc, oldP); DeleteObject(bDark); DeleteObject(pEdge); DeleteObject(bGreen); DeleteObject(pLine);
        return;
    }

    HPEN pNone = CreatePen(PS_NULL, 0, 0);
    HGDIOBJ oldP = SelectObject(dc, pNone);
    HBRUSH bShadow = CreateSolidBrush(RGB(180,180,180));
    HGDIOBJ oldB = SelectObject(dc, bShadow);
    Ellipse(dc, dx+s4, dy+h-s8, dx+w+s4, dy+h+s4);
    Rectangle(dc, dx+s4, dy+s10, dx+w+s4, dy+h);
    
    HBRUSH bBody = CreateSolidBrush(RGB(210, 215, 220));
    HPEN pEdge = CreatePen(PS_SOLID, s1, RGB(80, 80, 80));
    SelectObject(dc, bBody); SelectObject(dc, pEdge);
    Rectangle(dc, dx, dy+s10, dx+w, dy+h);
    Ellipse(dc, dx, dy+h-s8, dx+w, dy+h+s8);
    
    HPEN pRidge = CreatePen(PS_SOLID, s1, RGB(160, 160, 170));
    HPEN pHi = CreatePen(PS_SOLID, s1, RGB(240, 245, 250));
    for (int rx = dx + s6; rx < dx + w - s4; rx += s6) {
        SelectObject(dc, pRidge);
        MoveToEx(dc, rx, dy+s10, NULL); LineTo(dc, rx, dy+h+s2);
        SelectObject(dc, pHi);
        MoveToEx(dc, rx+s1, dy+s10, NULL); LineTo(dc, rx+s1, dy+h+s2);
    }

    SelectObject(dc, bBody); SelectObject(dc, pEdge);
    Ellipse(dc, dx, dy+s4, dx+w, dy+s10+s6);

    HBRUSH bLid = CreateSolidBrush(RGB(230, 235, 240));
    SelectObject(dc, bLid);
    Ellipse(dc, dx-s2, lidDy-s2, dx+w+s2, lidDy+s8);
    
    MoveToEx(dc, dx+w/2-s6, lidDy-s2, NULL);
    LineTo(dc, dx+w/2-s6, lidDy-s6);
    LineTo(dc, dx+w/2+s6, lidDy-s6);
    LineTo(dc, dx+w/2+s6, lidDy-s2);

    SelectObject(dc, oldP); SelectObject(dc, oldB);
    DeleteObject(pNone); DeleteObject(bShadow); DeleteObject(bBody); DeleteObject(pEdge);
    DeleteObject(pRidge); DeleteObject(pHi); DeleteObject(bLid);
}

static void DrawItemIcon(HDC dc, RECT r, const Item* it, float trashLidPct) {
    int w = r.right - r.left;
    if (it->type == IT_FOLDER) DrawFolderIcon(dc, r.left, r.top, w);
    else if (it->type == IT_TRASH) DrawTrashIcon(dc, r.left, r.top, w, trashLidPct);
    else if (it->type == IT_FILE) {
        int cIcon = GetCustomIconId(it);
        switch (cIcon) {
            case 2: DrawIcon_Microsoft(dc, r); break;
            case 3: DrawIcon_Terminal(dc, r); break;
            case 4: DrawIcon_Picture(dc, r); break;
            case 5: DrawIcon_Code(dc, r); break;
            case 0: DrawFolderIcon(dc, r.left, r.top, w); break;
            default: DrawFloppyIcon(dc, r.left, r.top, w); break;
        }
    }
}

static WindowCtx* Ctx(HWND h) { return (WindowCtx*)GetWindowLongPtrW(h, GWLP_USERDATA); }

static BOOL TopBar_PointInTrash(POINT scrPt) {
    if (!g_topBar) return FALSE; 
    RECT wr; GetWindowRect(g_topBar, &wr); RECT r = g_topBarTrash; OffsetRect(&r, wr.left, wr.top); return (scrPt.x>=r.left && scrPt.x<r.right && scrPt.y>=r.top && scrPt.y<r.bottom);
}

static void FS_ClearChildren(WindowCtx* c, int parentId) { 
    if (!c->items) return;
    for (int i = c->itemCount - 1; i >= 0; --i) 
        if (c->items[i].parent == parentId && c->items[i].type != IT_TRASH) 
            FS_DeleteItem(c, i); 
}

static void NextAppendPosition(WindowCtx* c, const Layout* L, int rootId, int* outCol, int* outRow) { 
    int maxRow = 0, maxCol = -1; 
    for (int i=0;i<c->itemCount;++i) { 
        if (c->items[i].parent==rootId && c->items[i].type!=IT_TRASH) { 
            if (c->items[i].gridRow > maxRow) { maxRow = c->items[i].gridRow; maxCol = c->items[i].gridCol; } 
            else if (c->items[i].gridRow == maxRow && c->items[i].gridCol > maxCol) { maxCol = c->items[i].gridCol; } 
        } 
    } 
    int col = (maxCol>=0)?(maxCol+1):0; 
    int row = maxRow; 
    int originX = L->content.left + L->xStart; 
    int usableW = L->content.right - originX; 
    int cols = max(1, usableW / L->colW); 
    if (col>=cols) { col = 0; row++; } 
    *outCol = col; *outRow = row; 
    FS_FindNextFree(c, L, rootId, outCol, outRow, -1); 
}

static void FS_AddItem(WindowCtx* c, ItemType t, const wchar_t* name, const wchar_t* desc, int col, int row, int parent, const Layout* L) { 
    if (!c->items || c->itemCount >= MAX_ITEMS) return; 
    if (col<0 || row<0) NextAppendPosition(c, L, parent, &col, &row); 
    Item it = {0}; it.type = t; lstrcpynW(it.name, name, 63); lstrcpynW(it.desc, desc?desc:L"", 127); it.gridCol = col; it.gridRow = row; it.parent = parent; it.selected = FALSE; 
    c->items[c->itemCount++] = it; 
}

static void FS_AddItemFS(WindowCtx* c, ItemType t, const wchar_t* name, const wchar_t* fullPath, int col, int row, int parent, const Layout* L, BOOL scannedFolder) { 
    if (!c->items || c->itemCount >= MAX_ITEMS) return; 
    if (col<0 || row<0) NextAppendPosition(c, L, parent, &col, &row); 
    Item it = {0}; it.type = t; lstrcpynW(it.name, name ? name : L"", 63); it.gridCol = col; it.gridRow = row; it.parent = parent; it.selected = FALSE; it.fromFS = TRUE; it.scanned = scannedFolder; 
    lstrcpynW(it.path, fullPath, MAX_PATH-1); 
    c->items[c->itemCount++] = it; 
}

static void FS_DeleteItem(WindowCtx* c, int idx) { 
    if (!c->items || idx < 0 || idx >= c->itemCount || idx == g_trashIndex) return; 
    for (int i=c->itemCount-1; i>=0; --i) { if (c->items[i].parent==idx) FS_DeleteItem(c, i); } 
    for (int i=idx; i<c->itemCount-1; ++i) { c->items[i] = c->items[i+1]; } 
    c->itemCount--; 
    if (g_trashIndex > idx) g_trashIndex--; 
    for (int i=0; i<c->itemCount; ++i) { if (c->items[i].parent>idx) c->items[i].parent--; } 
}

static void FS_ClearSelection(WindowCtx* c, int rootId) { 
    if (!c->items) return;
    for (int i=0;i<c->itemCount;++i) { if (c->items[i].parent==rootId && c->items[i].type!=IT_TRASH) c->items[i].selected = FALSE; } 
}

static BOOL FS_IsOccupied(WindowCtx* c, int rootId, int col, int row, int exceptIdx) { 
    for (int i=0;i<c->itemCount;++i) { 
        if (i==exceptIdx) continue; 
        if (c->items[i].parent==rootId && c->items[i].type!=IT_TRASH && c->items[i].gridCol==col && c->items[i].gridRow==row) return TRUE; 
    } return FALSE; 
}

static void FS_FindNextFree(WindowCtx* c, const Layout* L, int rootId, int* ioCol, int* ioRow, int exceptIdx) { 
    int originX = L->content.left + L->xStart; 
    int usableW = L->content.right - originX; 
    int cols = max(1, usableW / L->colW); 
    int col=*ioCol, row=*ioRow; 
    if (col<0) { col=0; } if (row<0) { row=0; } 
    for (int r=row; r<32000; ++r) { 
        for (int c_col=(r==row?col:0); c_col<cols; ++c_col) { 
            if (!FS_IsOccupied(c, rootId, c_col, r, exceptIdx)) { *ioCol=c_col; *ioRow=r; return; } 
        } 
    } 
    *ioCol=0; *ioRow=row+1; 
}

static void FS_SnapToGrid(WindowCtx* c, const Layout* L, int* ioCol, int* ioRow, int px, int py, int exceptIdx) { 
    int originX = L->content.left + L->xStart; 
    int originY = L->content.top  + L->yStart - c->scrollY; 
    int col = (int)floorf((px - originX + L->colW/2.0f) / (float)L->colW); 
    int row = (int)floorf((py - originY + L->rowH/2.0f) / (float)L->rowH); 
    if (col<0) { col=0; } if (row<0) { row=0; } 
    FS_FindNextFree(c, L, c->rootId, &col, &row, exceptIdx); 
    *ioCol = col; *ioRow = row; 
}

static int FS_HitTestItem(WindowCtx* c, const Layout* L, int x, int y) { 
    if (!c->items) return -1;
    for (int i=c->itemCount-1;i>=0;--i) { 
        if (c->items[i].parent != c->rootId) continue; 
        if (c->items[i].type == IT_TRASH) continue; 
        RECT rI, rL; ItemPixelRect(L, c, &c->items[i], &rI, &rL); 
        RECT hit = rI; InflateRect(&hit, S(6), S(6)); 
        if (PtIn(&hit, x, y)) return i; 
        RECT lab = rL; InflateRect(&lab, S(6), S(2)); 
        if (PtIn(&lab, x, y)) return i; 
    } return -1; 
}

static int FS_CmpItemName(const void* a, const void* b) { Item* ia = (Item*)a; Item* ib = (Item*)b; if (ia->type == IT_FOLDER && ib->type != IT_FOLDER) return -1; if (ia->type != IT_FOLDER && ib->type == IT_FOLDER) return 1; return lstrcmpiW(ia->name, ib->name); }
static int FS_CmpItemDate(const void* a, const void* b) { Item* ia = (Item*)a; Item* ib = (Item*)b; if (ia->type == IT_FOLDER && ib->type != IT_FOLDER) return -1; if (ia->type != IT_FOLDER && ib->type == IT_FOLDER) return 1; if (ia->lastWriteTime > ib->lastWriteTime) return -1; if (ia->lastWriteTime < ib->lastWriteTime) return 1; return 0; }
static int FS_CmpItemSize(const void* a, const void* b) { Item* ia = (Item*)a; Item* ib = (Item*)b; if (ia->type == IT_FOLDER && ib->type != IT_FOLDER) return -1; if (ia->type != IT_FOLDER && ib->type == IT_FOLDER) return 1; if (ia->sizeCache > ib->sizeCache) return -1; if (ia->sizeCache < ib->sizeCache) return 1; return 0; }

static void FS_PopulateOneLevel(WindowCtx* c, const wchar_t* dir, int parentId, const Layout* L) {
    wchar_t mask[MAX_PATH] = {0}; lstrcpynW(mask, dir, MAX_PATH-1); size_t n = wcslen(mask); if (n && (mask[n-1] != L'\\' && mask[n-1] != L'/')) { lstrcatW(mask, L"\\"); } lstrcatW(mask, L"*");
    WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd); if (h == INVALID_HANDLE_VALUE) return;
    
    int originX = L->content.left + L->xStart; int usableW = L->content.right - originX;
    int cols = max(1, usableW / L->colW); int curIdx = 0;
    
    do {
        if (FS_IsDotOrDotDot(&fd)) continue; 
        if (c->itemCount >= MAX_ITEMS - 1) break;
        
        wchar_t full[MAX_PATH] = {0}; lstrcpynW(full, dir, MAX_PATH-1); if (full[0] && full[wcslen(full)-1] != L'\\') lstrcatW(full, L"\\"); lstrcatW(full, fd.cFileName);
        BOOL isDir = (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0;
        
        Item it = {0}; it.type = isDir ? IT_FOLDER : IT_FILE;
        lstrcpynW(it.name, fd.cFileName, 63);
        it.gridCol = curIdx % cols; it.gridRow = curIdx / cols; it.parent = parentId;
        it.fromFS = TRUE; it.scanned = !isDir; it.scanProgress = 0.0f;
        it.lastWriteTime = ((ULONGLONG)fd.ftLastWriteTime.dwHighDateTime << 32) | fd.ftLastWriteTime.dwLowDateTime;
        it.sizeCache = isDir ? 0 : (((ULARGE_INTEGER*)&fd.nFileSizeLow)->QuadPart);
        lstrcpynW(it.path, full, MAX_PATH-1); 
        c->items[c->itemCount++] = it; curIdx++;
    } while (FindNextFileW(h, &fd)); FindClose(h);
}

static void FS_PopulateRootFromPath(WindowCtx* c, const wchar_t* dir, const Layout* L) {
    if (!c->items) return;
    if (lstrcmpW(dir, L":Search:") == 0) return;
    if (lstrcmpW(dir, L":Computer:") == 0) { 
        lstrcpynW(c->fsRootPath, L":Computer:", MAX_PATH-1); 
        FS_ClearChildren(c, -1); 
        wchar_t drives[256] = {0}; DWORD r = GetLogicalDriveStringsW(255, drives); 
        if (r > 0) { wchar_t* p = drives; while (*p) { wchar_t name[16] = {0}; lstrcpynW(name, p, 15); FS_AddItemFS(c, IT_FOLDER, name, p, -1, -1, -1, L, TRUE); p += lstrlenW(p) + 1; } } 
        return; 
    }
    lstrcpynW(c->fsRootPath, dir, MAX_PATH-1); 
    FS_ClearChildren(c, -1); 
    FS_PopulateOneLevel(c, dir, -1, L);
}

static void SetupDirectoryMonitor(HWND h, WindowCtx* c, const wchar_t* path) { 
    if (c->hDirMonitor) { FindCloseChangeNotification(c->hDirMonitor); c->hDirMonitor = NULL; } 
    if (path && path[0] && lstrcmpW(path, L":Computer:") != 0 && lstrcmpW(path, L":Search:") != 0) { 
        c->hDirMonitor = FindFirstChangeNotificationW(path, FALSE, FILE_NOTIFY_CHANGE_FILE_NAME | FILE_NOTIFY_CHANGE_DIR_NAME | FILE_NOTIFY_CHANGE_SIZE); 
    } 
}

static void DrawStatusLine(HDC dc, const Layout* L, WindowCtx* c) {
    HPEN pen = CreatePen(PS_SOLID, S(1), RGB(0,0,0)); HGDIOBJ oldPen = SelectObject(dc, pen);
    MoveToEx(dc, L->content.left, L->content.top, NULL); LineTo(dc, L->content.right, L->content.top); SelectObject(dc, oldPen); DeleteObject(pen);

    HFONT font = NULL; PickClassicFont(&font, 12, FALSE); HGDIOBJ old = SelectObject(dc, font);
    RECT seg = L->content; seg.top += S(2); seg.bottom = seg.top + S(18);
    
    int cnt = 0; ULONGLONG selSize = 0; BOOL hasSelection = FALSE;
    for (int i=0;i<c->itemCount;++i) { if (c->items[i].parent == c->rootId && c->items[i].type != IT_TRASH) { cnt++; if (c->items[i].selected) { hasSelection = TRUE; if (c->items[i].fromFS && c->items[i].path[0]) selSize += FS_GetFileSizeBytes(c->items[i].path); } } }
    ULONGLONG freeSpaceK = 0;
    
    wchar_t currentPath[MAX_PATH] = L"";
    if (c->rootId >= 0 && c->items[c->rootId].fromFS) lstrcpynW(currentPath, c->items[c->rootId].path, MAX_PATH);
    else if (c->fsRootPath[0]) lstrcpynW(currentPath, c->fsRootPath, MAX_PATH);

    if (currentPath[0]) { ULARGE_INTEGER freeBytes; if (GetDiskFreeSpaceExW(currentPath, &freeBytes, NULL, NULL)) freeSpaceK = freeBytes.QuadPart / 1024; }

    RECT lR = seg; lR.left += S(6); lR.right = lR.left + S(300);
    TextOutAlign(dc, lR.left, lR.top + S(2), currentPath[0]?currentPath:L"(Virtual)", TA_LEFT | TA_TOP);

    wchar_t mid[64];
    if (hasSelection) {
        if (selSize < 1024) _snwprintf(mid, 63, L"Sel: %llu B", (unsigned long long)selSize);
        else if (selSize < 1024*1024) _snwprintf(mid, 63, L"Sel: %.2f KB", selSize / 1024.0);
        else if (selSize < 1024*1024*1024) _snwprintf(mid, 63, L"Sel: %.2f MB", selSize / 1048576.0);
        else _snwprintf(mid, 63, L"Sel: %.2f GB", selSize / 1073741824.0);
    } else { _snwprintf(mid, 63, L"%d items", cnt); }
    TextOutAlign(dc, (seg.left+seg.right)/2, seg.top + S(2), mid, TA_TOP | TA_CENTER);
    
    wchar_t right[64];
    if (freeSpaceK > 0) {
        ULONGLONG freeSpaceB = freeSpaceK * 1024ULL;
        if (freeSpaceB < 1024) _snwprintf(right, 63, L"%llu B free", (unsigned long long)freeSpaceB);
        else if (freeSpaceB < 1024*1024) _snwprintf(right, 63, L"%.2f KB free", freeSpaceB / 1024.0);
        else if (freeSpaceB < 1024*1024*1024) _snwprintf(right, 63, L"%.2f MB free", freeSpaceB / 1048576.0);
        else _snwprintf(right, 63, L"%.2f GB free", freeSpaceB / 1073741824.0);
    } else lstrcpyW(right, L"");
    TextOutAlign(dc, seg.right - S(6), seg.top + S(2), right, TA_TOP | TA_RIGHT);
    
    SelectObject(dc, old); DeleteObject(font);
}

static void ItemPixelRect(const Layout* L, const WindowCtx* c, const Item* it, RECT* outIcon, RECT* outLabel) {
    int originX = L->content.left + L->xStart; int originY = L->content.top  + L->yStart - (c ? c->scrollY : 0);
    int x = originX + it->gridCol * L->colW; int y = originY + it->gridRow * L->rowH;
    outIcon->left   = x; outIcon->top    = y; outIcon->right  = x + L->iconSize; outIcon->bottom = y + L->iconSize;
    outLabel->left  = x; outLabel->top   = y + L->iconSize + S(8); outLabel->right = x + L->iconSize; outLabel->bottom= outLabel->top + L->labelH;
}

static void DrawOneItem(HDC dc, const Layout* L, const WindowCtx* c, const Item* it) {
    RECT rI, rL; ItemPixelRect(L, c, it, &rI, &rL);
    if (it->selected) { RECT hl = rI; InflateRect(&hl, S(6), S(6)); hl.bottom = rL.bottom + S(6); HBRUSH hbr = CreateSolidBrush(RGB(200, 220, 255)); HPEN hlPen = CreatePen(PS_SOLID, S(1), RGB(100, 150, 255)); HGDIOBJ oldP = SelectObject(dc, hlPen); HGDIOBJ oldB = SelectObject(dc, hbr); RoundRect(dc, hl.left, hl.top, hl.right, hl.bottom, S(8), S(8)); SelectObject(dc, oldB); SelectObject(dc, oldP); DeleteObject(hbr); DeleteObject(hlPen); }
    
    RECT icR = { rI.left, rI.top, rI.right, rI.bottom };
    DrawItemIcon(dc, icR, it, 0.0f);
    
    HFONT font = NULL; PickClassicFont(&font, 12, FALSE); HGDIOBJ old = SelectObject(dc, font); SetBkMode(dc, TRANSPARENT); 
    
    RECT txtR; txtR.top = rL.top; txtR.bottom = rL.top + L->labelH * 2; txtR.left = rI.left + L->iconSize/2 - L->colW/2 + S(4); txtR.right = rI.left + L->iconSize/2 + L->colW/2 - S(4); 
    
    if (g_darkMode) {
        SetTextColor(dc, RGB(50, 150, 0)); 
        RECT r1 = txtR; OffsetRect(&r1, -1, -1); DrawTextW(dc, it->name, -1, &r1, DT_CENTER | DT_TOP | DT_NOPREFIX | DT_END_ELLIPSIS | DT_SINGLELINE);
        RECT r2 = txtR; OffsetRect(&r2, 1, -1); DrawTextW(dc, it->name, -1, &r2, DT_CENTER | DT_TOP | DT_NOPREFIX | DT_END_ELLIPSIS | DT_SINGLELINE);
        RECT r3 = txtR; OffsetRect(&r3, -1, 1); DrawTextW(dc, it->name, -1, &r3, DT_CENTER | DT_TOP | DT_NOPREFIX | DT_END_ELLIPSIS | DT_SINGLELINE);
        RECT r4 = txtR; OffsetRect(&r4, 1, 1); DrawTextW(dc, it->name, -1, &r4, DT_CENTER | DT_TOP | DT_NOPREFIX | DT_END_ELLIPSIS | DT_SINGLELINE);
        
        SetTextColor(dc, RGB(180, 255, 0));
    } else {
        SetTextColor(dc, RGB(0, 0, 0));
    }
    DrawTextW(dc, it->name, -1, &txtR, DT_CENTER | DT_TOP | DT_NOPREFIX | DT_END_ELLIPSIS | DT_SINGLELINE);
    
    if (g_multiSelectMode) { int s = S(14); RECT chk = { rI.left - S(4), rI.top - S(4), rI.left - S(4) + s, rI.top - S(4) + s }; HBRUSH bg = CreateSolidBrush(RGB(255,255,255)); FillRect(dc, &chk, bg); DeleteObject(bg); HPEN pen = CreatePen(PS_SOLID, S(1), RGB(0,0,0)); HGDIOBJ oldP = SelectObject(dc, pen); Rectangle(dc, chk.left, chk.top, chk.right, chk.bottom); if (it->selected) { MoveToEx(dc, chk.left+S(2), chk.top+S(7), NULL); LineTo(dc, chk.left+S(6), chk.bottom-S(3)); LineTo(dc, chk.right-S(2), chk.top+S(2)); } SelectObject(dc, oldP); DeleteObject(pen); }
    
    if ((it->type == IT_FOLDER || it->type == IT_FILE) && !it->scanned) {
        int r = L->iconSize / 4; 
        int cx = rI.right - r, cy = rI.bottom - r;
        HPEN pR = CreatePen(PS_SOLID, 1, RGB(0,0,0)); HGDIOBJ oldP = SelectObject(dc, pR);
        HBRUSH bgRing = CreateSolidBrush(RGB(255,255,255)); HGDIOBJ oldB = SelectObject(dc, bgRing);
        Ellipse(dc, cx-r, cy-r, cx+r, cy+r);
        
        if (it->scanProgress > 0.0f) {
            HBRUSH yel = CreateSolidBrush(RGB(255, 200, 0)); SelectObject(dc, yel);
            double angle = (it->scanProgress * 360.0f) * 3.14159265 / 180.0;
            int endX = cx + (int)(r * sin(angle));
            int endY = cy - (int)(r * cos(angle));
            Pie(dc, cx-r, cy-r, cx+r, cy+r, endX, endY, cx, cy-r);
            DeleteObject(yel);
        }
        
        SelectObject(dc, oldB); DeleteObject(bgRing);
        SelectObject(dc, oldP); DeleteObject(pR);
    }
    
    BOOL isComputer = (c->rootId == -1 && lstrcmpW(c->fsRootPath, L":Computer:") == 0);
    if (isComputer && it->path[0]) {
        ULARGE_INTEGER freeBytesToCaller, totalBytes, freeBytes;
        if (GetDiskFreeSpaceExW(it->path, &freeBytesToCaller, &totalBytes, &freeBytes)) {
            double usedPct = 0.0;
            if (totalBytes.QuadPart > 0) usedPct = (double)(totalBytes.QuadPart - freeBytes.QuadPart) / (double)totalBytes.QuadPart;
            
            int bw = S(8);
            RECT barR = { rI.right + S(6), rI.top + S(4), rI.right + S(6) + bw, rI.bottom - S(4) };
            HPEN pEdge = CreatePen(PS_SOLID, 1, RGB(100,100,100)); 
            HBRUSH bBg = CreateSolidBrush(RGB(230,230,230));
            HGDIOBJ oP = SelectObject(dc, pEdge); 
            HGDIOBJ oB = SelectObject(dc, bBg);
            Rectangle(dc, barR.left, barR.top, barR.right, barR.bottom);
            SelectObject(dc, oB); DeleteObject(bBg);
            
            int fillH = (int)((barR.bottom - barR.top) * usedPct);
            RECT fillR = { barR.left + 1, barR.bottom - fillH, barR.right - 1, barR.bottom - 1 };
            if (fillR.top < barR.top + 1) fillR.top = barR.top + 1;
            
            if (fillH > 0) {
                HBRUSH bFill = CreateSolidBrush(usedPct > 0.9 ? RGB(220,60,60) : RGB(60,180,80));
                FillRect(dc, &fillR, bFill); 
                DeleteObject(bFill);
            }
            SelectObject(dc, oP); DeleteObject(pEdge);
            
            wchar_t szStr[64];
            double totalGB = totalBytes.QuadPart / (1024.0*1024.0*1024.0);
            double freeGB = freeBytes.QuadPart / (1024.0*1024.0*1024.0);
            _snwprintf(szStr, 63, L"%.1f/%.1f GB (%.0f%%)", totalGB - freeGB, totalGB, usedPct * 100.0);
            
            RECT stR = txtR; 
            stR.top = txtR.top + L->labelH; 
            stR.bottom = stR.top + L->labelH;
            
            HFONT sFont = NULL; PickClassicFont(&sFont, 11, FALSE);
            SelectObject(dc, sFont); 
            SetTextColor(dc, RGB(80,80,80));
            DrawTextW(dc, szStr, -1, &stR, DT_CENTER | DT_TOP | DT_NOPREFIX | DT_SINGLELINE);
            SelectObject(dc, font); DeleteObject(sFont);
        }
    }
    
    SelectObject(dc, old); DeleteObject(font);
}

