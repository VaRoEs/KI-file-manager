static void DrawRainbowApple(HDC dc, RECT r) {
    const char* apple24[24] = { "           ...          ", "          .....         ", "         .....          ", "          ...           ", "                        ", "       ..........       ", "     ..GGGGGGGGGG..     ", "    .GGGGGGGGGGGG..     ", "   .GGGGGGGGGGGGGG..    ", "  .YYYYYYYYYYYYYYYY.    ", "  .YYYYYYYYYYYYYYY..    ", "  .OOOOOOOOOOOO.......  ", "  .OOOOOOOOOOO......... ", "  .RRRRRRRRRR.......... ", "   .RRRRRRRRR.........  ", "   .PPPPPPPPPP.......   ", "    .PPPPPPPPPPPPP..    ", "    .BBBBBBBBBBBB..     ", "     .BBBBBBBBBB..      ", "      ..BBBBBB...       ", "        .......         ", "                        ", "                        ", "                        " };
    int w = r.right - r.left, h = r.bottom - r.top; float pxW = w / 24.0f, pxH = h / 24.0f;
    HBRUSH bG = CreateSolidBrush(RGB(97, 187, 70)); HBRUSH bY = CreateSolidBrush(RGB(253, 184, 39)); HBRUSH bO = CreateSolidBrush(RGB(245, 130, 31)); HBRUSH bR = CreateSolidBrush(RGB(224, 58, 62)); HBRUSH bP = CreateSolidBrush(RGB(150, 61, 151)); HBRUSH bB = CreateSolidBrush(RGB(0, 157, 220)); HBRUSH bBlk = CreateSolidBrush(RGB(0, 0, 0));
    for (int y=0; y<24; y++) {
        for (int x=0; x<24; x++) {
            char c = apple24[y][x]; if (c == ' ') continue;
            HBRUSH br = bBlk; if (c == 'G') br = bG; else if (c == 'Y') br = bO; else if (c == 'O') br = bO; else if (c == 'R') br = bR; else if (c == 'P') br = bP; else if (c == 'B') br = bB;
            RECT pr = { r.left + (int)(x*pxW), r.top + (int)(y*pxH), r.left + (int)((x+1)*pxW) + 1, r.top + (int)((y+1)*pxH) + 1 }; FillRect(dc, &pr, br);
        }
    } DeleteObject(bG); DeleteObject(bY); DeleteObject(bO); DeleteObject(bR); DeleteObject(bP); DeleteObject(bB); DeleteObject(bBlk);
}

