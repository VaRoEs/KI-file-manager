static void PickClassicFont(HFONT *outFont, int heightPx, BOOL bold) {
    LOGFONTW lf = {0}; lf.lfHeight = -S(heightPx); lf.lfWeight = bold ? FW_BOLD : FW_NORMAL; lf.lfQuality = ANTIALIASED_QUALITY;
    const wchar_t* candidates[] = { L"Chicago", L"Geneva", L"Charcoal", L"MS Sans Serif", L"System" };
    HFONT f = NULL; for (int i=0;i<5; ++i) { lstrcpyW(lf.lfFaceName, candidates[i]); f = CreateFontIndirectW(&lf); if (f) break; }
    if (!f) { f = (HFONT)GetStockObject(SYSTEM_FONT); }
    *outFont = f;
}

