static BOOL FS_IsDotOrDotDot(const WIN32_FIND_DATAW* fd) { return (lstrcmpW(fd->cFileName, L".") == 0 || lstrcmpW(fd->cFileName, L"..") == 0); }
static void ItemSetPath(Item* it, const wchar_t* fullPath) { if (!fullPath) { it->path[0] = 0; return; } lstrcpynW(it->path, fullPath, MAX_PATH-1); it->fromFS = TRUE; }
static void FS_ClearChildren(int parentId) { for (int i=g_itemCount-1; i>=0; --i) if (g_items[i].parent == parentId && g_items[i].type != IT_TRASH) DeleteItem(i); }

static void AddItemFS(ItemType t, const wchar_t* name, const wchar_t* fullPath, int col, int row, int parent, const Layout* L, BOOL scannedFolder) { if (g_itemCount >= MAX_ITEMS) return; if (col<0 || row<0) NextAppendPosition(L, parent, &col, &row); Item it = {0}; it.type = t; lstrcpynW(it.name, name ? name : L"", 63); it.gridCol = col; it.gridRow = row; it.parent  = parent; it.selected = FALSE; it.fromFS = TRUE; it.scanned = scannedFolder; ItemSetPath(&it, fullPath); g_items[g_itemCount++] = it; }
static void FS_PopulateOneLevel(const wchar_t* dir, int parentId, const Layout* L) {
    wchar_t mask[MAX_PATH]; lstrcpynW(mask, dir, MAX_PATH-1); size_t n = wcslen(mask); if (n && (mask[n-1] != L'\\' && mask[n-1] != L'/')) { lstrcatW(mask, L"\\"); } lstrcatW(mask, L"*");
    WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd); if (h == INVALID_HANDLE_VALUE) return;
    
    int originX = L->content.left + L->xStart;
    int usableW = L->content.right - originX;
    int cols = max(1, usableW / L->colW);
    int curIdx = 0;
    
    do {
        if (FS_IsDotOrDotDot(&fd)) continue; 
        if (g_itemCount >= MAX_ITEMS - 1) break;
        
        wchar_t full[MAX_PATH]; lstrcpynW(full, dir, MAX_PATH-1); if (full[0] && full[wcslen(full)-1] != L'\\') lstrcatW(full, L"\\"); lstrcatW(full, fd.cFileName);
        BOOL isDir = (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0;
        
        Item it = {0};
        it.type = isDir ? IT_FOLDER : IT_FILE;
        lstrcpynW(it.name, fd.cFileName, 63);
        it.gridCol = curIdx % cols;
        it.gridRow = curIdx / cols;
        it.parent = parentId;
        it.fromFS = TRUE;
        it.scanned = !isDir;
        it.lastWriteTime = ((ULONGLONG)fd.ftLastWriteTime.dwHighDateTime << 32) | fd.ftLastWriteTime.dwLowDateTime;
        it.sizeCache = isDir ? 0 : (((ULARGE_INTEGER*)&fd.nFileSizeLow)->QuadPart);
        ItemSetPath(&it, full);
        g_items[g_itemCount++] = it;
        
        curIdx++;
    } while (FindNextFileW(h, &fd)); FindClose(h);
}

static void FS_PopulateRootFromPath(const wchar_t* dir, const Layout* L) {
    if (lstrcmpW(dir, L":Search:") == 0) return;
    if (lstrcmpW(dir, L":Computer:") == 0) { lstrcpynW(g_fsRootPath, L":Computer:", MAX_PATH-1); FS_ClearChildren(-1); wchar_t drives[256]; DWORD r = GetLogicalDriveStringsW(255, drives); if (r > 0) { wchar_t* p = drives; while (*p) { wchar_t name[16]; lstrcpynW(name, p, 15); AddItemFS(IT_FOLDER, name, p, -1, -1, -1, L, TRUE); p += lstrlenW(p) + 1; } } return; }
    lstrcpynW(g_fsRootPath, dir, MAX_PATH-1); FS_ClearChildren(-1); FS_PopulateOneLevel(dir, -1, L);
}

static void SetupDirectoryMonitor(HWND h, WindowCtx* c, const wchar_t* path) { if (c->hDirMonitor) { FindCloseChangeNotification(c->hDirMonitor); c->hDirMonitor = NULL; } if (path && path[0] && lstrcmpW(path, L":Computer:") != 0 && lstrcmpW(path, L":Search:") != 0) { c->hDirMonitor = FindFirstChangeNotificationW(path, FALSE, FILE_NOTIFY_CHANGE_FILE_NAME | FILE_NOTIFY_CHANGE_DIR_NAME | FILE_NOTIFY_CHANGE_SIZE); } }

static int CmpItemName(const void* a, const void* b) {
    Item* ia = (Item*)a; Item* ib = (Item*)b;
    if (ia->type == IT_FOLDER && ib->type != IT_FOLDER) return -1;
    if (ia->type != IT_FOLDER && ib->type == IT_FOLDER) return 1;
    return lstrcmpiW(ia->name, ib->name);
}

static int CmpItemDate(const void* a, const void* b) {
    Item* ia = (Item*)a; Item* ib = (Item*)b;
    if (ia->type == IT_FOLDER && ib->type != IT_FOLDER) return -1;
    if (ia->type != IT_FOLDER && ib->type == IT_FOLDER) return 1;
    if (ia->lastWriteTime > ib->lastWriteTime) return -1;
    if (ia->lastWriteTime < ib->lastWriteTime) return 1;
    return 0;
}

static int CmpItemSize(const void* a, const void* b) {
    Item* ia = (Item*)a; Item* ib = (Item*)b;
    if (ia->type == IT_FOLDER && ib->type != IT_FOLDER) return -1;
    if (ia->type != IT_FOLDER && ib->type == IT_FOLDER) return 1;
    if (ia->sizeCache > ib->sizeCache) return -1;
    if (ia->sizeCache < ib->sizeCache) return 1;
    return 0;
}

