static void SetClipboardText(HWND owner, const wchar_t* text) {
    if (!text || !*text) return;
    if (!OpenClipboard(owner)) return;
    EmptyClipboard();
    SIZE_T bytes = (wcslen(text)+1)*sizeof(wchar_t);
    HGLOBAL h = GlobalAlloc(GMEM_MOVEABLE, bytes);
    if (h) {
        void* p = GlobalLock(h);
        if (p) { memcpy(p, text, bytes); GlobalUnlock(h); SetClipboardData(CF_UNICODETEXT, h); }
        else GlobalFree(h);
    }
    CloseClipboard();
}

static void TrimInPlaceW(wchar_t* s) {
    if (!s) return;
    wchar_t* p = s; while (*p==L' '||*p==L'\t'||*p==L'\r'||*p==L'\n'||*p==L'\"'||*p==L'\'') ++p;
    if (p!=s) { size_t k=0; while (p[k]) { s[k]=p[k]; ++k; } s[k]=0; }
    size_t n = lstrlenW(s);
    while (n>0) {
        wchar_t c = s[n-1];
        if (c==L' '||c==L'\t'||c==L'\r'||c==L'\n'||c==L'\"'||c==L'\'') { s[n-1]=0; --n; }
        else break;
    }
}

static int SplitLinesToArray(const wchar_t* text, wchar_t** outArr, int maxItems) {
    int count = 0; const wchar_t* s = text;
    while (*s && count < maxItems) {
        const wchar_t* e = s; while (*e && *e!=L'\r' && *e!=L'\n') ++e;
        int len = (int)(e - s);
        if (len > 0) {
            outArr[count] = (wchar_t*)LocalAlloc(LMEM_FIXED, (len+1)*sizeof(wchar_t));
            if (outArr[count]) { lstrcpynW(outArr[count], s, len+1); TrimInPlaceW(outArr[count]); if (outArr[count][0]) count++; else { LocalFree(outArr[count]); outArr[count]=NULL; } }
        }
        while (*e==L'\r' || *e==L'\n') ++e;
        s = e;
    } return count;
}

static void FreeArray(wchar_t** arr, int count) { for (int i=0;i<count;i++) if (arr[i]) LocalFree(arr[i]); }

static wchar_t* BuildDoubleNullMultiString(wchar_t** arr, int count) {
    size_t total = 1; for (int i=0;i<count;i++) total += lstrlenW(arr[i]) + 1;
    wchar_t* buf = (wchar_t*)LocalAlloc(LMEM_FIXED, total * sizeof(wchar_t));
    if (!buf) return NULL;
    wchar_t* p = buf; for (int i=0;i<count;i++) { lstrcpyW(p, arr[i]); p += lstrlenW(p)+1; } *p = 0; return buf;
}

static void CreateLink(LPCWSTR lpszPathObj, LPCWSTR lpszPathLink, LPCWSTR lpszDesc) {
    IShellLinkW* psl;
    if (SUCCEEDED(CoCreateInstance(&CLSID_ShellLink, NULL, CLSCTX_INPROC_SERVER, &IID_IShellLinkW, (LPVOID*)&psl))) {
        psl->lpVtbl->SetPath(psl, lpszPathObj); psl->lpVtbl->SetDescription(psl, lpszDesc);
        IPersistFile* ppf;
        if (SUCCEEDED(psl->lpVtbl->QueryInterface(psl, &IID_IPersistFile, (LPVOID*)&ppf))) { ppf->lpVtbl->Save(ppf, lpszPathLink, TRUE); ppf->lpVtbl->Release(ppf); }
        psl->lpVtbl->Release(psl);
    }
}

