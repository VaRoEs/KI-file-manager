    SelectObject(dc, penWhite); MoveToEx(dc, r.left+S(1), r.bottom-S(2), NULL); LineTo(dc, r.left+S(1), r.top+S(1)); LineTo(dc, r.right-S(2), r.top+S(1));
    SelectObject(dc, penGray); MoveToEx(dc, r.right-S(2), r.top+S(1), NULL); LineTo(dc, r.right-S(2), r.bottom-S(2)); LineTo(dc, r.left+S(1), r.bottom-S(2));
    SelectObject(dc, oldBr); SelectObject(dc, old); DeleteObject(penBlack); DeleteObject(penWhite); DeleteObject(penGray);
