            if (hit>=0 && g_items[hit].type!=IT_TRASH) { items[n++] = (MenuItem){L"Rename", CMD_RENAME, TRUE}; items[n++] = (MenuItem){L"Delete", CMD_DELETE, TRUE}; items[n++] = (MenuItem){L"Cut", CMD_CUT, TRUE}; items[n++] = (MenuItem){L"Copy", CMD_COPY, TRUE}; items[n++] = (MenuItem){L"Create Shortcut", CMD_CREATE_SHORTCUT, TRUE}; if (g_items[hit].parent>=0 && g_items[g_items[hit].parent].type==IT_GROUP) { items[n++] = (MenuItem){L"Remove from Group", CMD_REMOVE_FROM_GROUP, TRUE}; } }
            items[n++] = (MenuItem){L"Paste", CMD_PASTE, TRUE}; items[n++] = (MenuItem){L"Create Folder", CMD_NEW_FOLDER, TRUE}; items[n++] = (MenuItem){L"Create File",   CMD_NEW_FILE,   TRUE}; items[n++] = (MenuItem){L"Create Group",  CMD_NEW_GROUP,  TRUE}; items[n++] = (MenuItem){L"Computer",  CMD_COMPUTER,  TRUE};
            items[n++] = (MenuItem){L"Refresh", CMD_REFRESH, TRUE}; items[n++] = (MenuItem){L"Sort by Date", CMD_SORT_DATE, TRUE}; items[n++] = (MenuItem){L"Sort by Name", CMD_SORT_NAME, TRUE}; items[n++] = (MenuItem){L"Sort by Size", CMD_SORT_SIZE, TRUE};
            POINT pt = { mx, my }; ClientToScreen(h, &pt); UINT sel = ShowMacMenu(h, pt, items, n); if (sel) PostMessage(h, WM_COMMAND, sel, 0);
        } return 0;
        case WM_PAINT: { PAINTSTRUCT ps; HDC dc = BeginPaint(h, &ps); Layout L; ComputeLayout(h, &L); UpdateScrollBounds(c, &L); HDC mem = CreateCompatibleDC(dc); HBITMAP bmp = CreateCompatibleBitmap(dc, L.client.right, L.client.bottom); HGDIOBJ old = SelectObject(mem, bmp); PaintAll(h, mem, &L); BitBlt(dc, 0, 0, L.client.right, L.client.bottom, mem, 0, 0, SRCCOPY); SelectObject(mem, old); DeleteObject(bmp); DeleteDC(mem); EndPaint(h, &ps); } return 0;
        case WM_APP+2: {
            Layout L; ComputeLayout(h, &L);
            if (lstrcmpW(g_navHistory[g_navDepth], L":Search:") == 0) { c->rootId = -2; } else {
                c->rootId = -1;
                if (g_navDepth==0 && lstrcmpW(g_navHistory[0], L":Computer:")!=0) { wchar_t startDir[MAX_PATH]; GetDesktopPath(startDir); lstrcpynW(g_navHistory[0], startDir, MAX_PATH); FS_PopulateRootFromPath(startDir, &L); }
                else FS_PopulateRootFromPath(g_navHistory[g_navDepth], &L); 
            } InvalidateRect(h, NULL, TRUE);
        } return 0;
        case WM_DESTROY: { UnregisterHotKey(h, 99); if (c) { if(c->hDirMonitor) FindCloseChangeNotification(c->hDirMonitor); if (c->renFont) DeleteObject(c->renFont); HeapFree(GetProcessHeap(), 0, c); } g_windowCount--; if (g_windowCount<=0) PostQuitMessage(0); return 0; }
    } return DefWindowProcW(h, m, w, l);
}

