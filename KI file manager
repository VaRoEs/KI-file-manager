static LRESULT CALLBACK MenuProc(HWND w, UINT m, WPARAM wp, LPARAM lp) {
    MenuState* st = (MenuState*)GetWindowLongPtrW(w, GWLP_USERDATA);
    switch (m) {
        case WM_CREATE: { CREATESTRUCTW* cs = (CREATESTRUCTW*)lp; st = (MenuState*)cs->lpCreateParams; SetWindowLongPtrW(w, GWLP_USERDATA, (LONG_PTR)st); st->hot = -1; st->shown = 0; st->curH = S(8); SetCapture(w); SetTimer(w, 1, 70, NULL); } return 0;
        case WM_TIMER: { if (wp==1) { if (st->shown < st->count) { st->shown++; int targetH = S(20)*st->shown + S(10); RECT wr; GetWindowRect(w, &wr); SetWindowPos(w, NULL, wr.left, wr.top, wr.right-wr.left, targetH, SWP_NOZORDER|SWP_NOMOVE); InvalidateRect(w, NULL, FALSE); } else KillTimer(w,1); } } return 0;
        case WM_MOUSEMOVE: { int y = GET_Y_LPARAM(lp); int h = S(20); int idx = y / h; if (idx >=0 && idx < st->shown && st->items[idx].enabled) st->hot = idx; else st->hot = -1; InvalidateRect(w, NULL, FALSE); } return 0;
        case WM_LBUTTONUP: { 
            ReleaseCapture(); 
            int y = GET_Y_LPARAM(lp); int h = S(20); int idx = y / h; 
            int cmd = (idx>=0 && idx<st->shown && st->items[idx].enabled) ? st->items[idx].id : 0; 
            if (cmd) PostMessageW(w, WM_COMMAND, MAKEWPARAM(cmd, 0), 0); 
            else DestroyWindow(w); 
        } return 0;
        case WM_COMMAND: { DestroyWindow(w); } return 0;
        case WM_KEYDOWN: if (wp==VK_ESCAPE) { ReleaseCapture(); DestroyWindow(w); } return 0;
        case WM_KILLFOCUS: ReleaseCapture(); DestroyWindow(w); return 0;
        case WM_ERASEBKGND: return 1;
        case WM_PAINT: { PAINTSTRUCT ps; HDC dc = BeginPaint(w, &ps); RECT r; GetClientRect(w, &r); HBRUSH wbr = (HBRUSH)GetStockObject(WHITE_BRUSH); FillRect(dc, &r, wbr); DrawClassicBezel(dc, r); HFONT f; PickClassicFont(&f, 12, FALSE); HGDIOBJ of = SelectObject(dc, f); SetBkMode(dc, TRANSPARENT); int h = S(20); for (int i=0;i<st->shown && i<st->count;++i) { RECT ri = { r.left+S(6), r.top + i*h, r.right-S(6), r.top + (i+1)*h }; if (st->hot==i) { HBRUSH g = CreateSolidBrush(RGB(220,220,220)); FillRect(dc, &ri, g); DeleteObject(g); } TextOutW(dc, ri.left, ri.top+S(3), st->items[i].text, lstrlenW(st->items[i].text)); } SelectObject(dc, of); DeleteObject(f); EndPaint(w, &ps); } return 0;
        case WM_DESTROY: { if (st) HeapFree(GetProcessHeap(), 0, st); } return 0;
    } return DefWindowProcW(w, m, wp, lp);
