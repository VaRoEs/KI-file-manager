    wc = (WNDCLASSW){0}; wc.lpfnWndProc = TopBarProc; wc.hInstance = hInst; wc.hCursor = LoadCursor(NULL, IDC_ARROW); wc.hbrBackground = (HBRUSH)(COLOR_WINDOW+1); wc.lpszClassName = kTopBarClass; RegisterClassW(&wc);
