static void FindNextFree(const Layout* L, int rootId, int* ioCol, int* ioRow, int exceptIdx) { int originX = L->content.left + L->xStart; int originY = L->content.top  + L->yStart; int usableW = L->content.right - originX; int usableH = (L->content.bottom - S(24)) - originY; int cols = max(1, usableW / L->colW); int rows = max(1, usableH / L->rowH); int col=*ioCol, row=*ioRow; if (col<0) { col=0; } if (row<0) { row=0; } for (int r=row; r<rows+100; ++r) { for (int c=(r==row?col:0); c<cols; ++c) { if (!IsOccupied(rootId, c, r, exceptIdx)) { *ioCol=c; *ioRow=r; return; } } } *ioCol=0; *ioRow=row+1; }
