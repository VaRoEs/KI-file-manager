static void ComputeLayout(HWND h, Layout* L) {
    GetClientRect(h, &L->client); L->outer = L->client; L->titleBar = L->outer; L->titleBar.bottom = L->titleBar.top + S(28);
    L->annex = L->outer; L->annex.top = L->titleBar.bottom; L->annex.right = L->annex.left + S(48); 
    L->content  = L->outer; L->content.top = L->titleBar.bottom + S(4); L->content.left = L->annex.right + S(4);
    int cb = S(12); L->closeBox.left   = L->titleBar.left + S(8); L->closeBox.top    = L->titleBar.top + ( ( (L->titleBar.bottom - L->titleBar.top) - cb ) / 2 );
    L->closeBox.right  = L->closeBox.left + cb; L->closeBox.bottom = L->closeBox.top + cb;
    int gb = S(16); L->growBox.right  = L->content.right - S(6); L->growBox.bottom = L->content.bottom - S(6);
    L->growBox.left   = L->growBox.right - gb; L->growBox.top    = L->growBox.bottom - gb;
    L->scrollRect.right = L->content.right; L->scrollRect.left  = L->content.right - S(16);
    L->scrollRect.top   = L->content.top; L->scrollRect.bottom= L->growBox.top; L->content.right -= S(16); 
    L->iconSize = S( (int)(56 * g_iconScale) ); L->labelH   = S(18); L->colW     = S( (int)(140 * g_iconScale) );
    L->rowH     = L->iconSize + S(8) + L->labelH + S(30); L->xStart   = S(16); L->yStart   = S(10) + L->labelH + S(8);
}

static void UpdateScrollBounds(WindowCtx* c, const Layout* L) {
    int maxR = 0; for (int i=0;i<g_itemCount;++i) { if (g_items[i].parent == c->rootId && g_items[i].type != IT_TRASH) { if (g_items[i].gridRow > maxR) maxR = g_items[i].gridRow; } }
    int contentH = L->yStart + (maxR + 1) * L->rowH; int viewH = L->content.bottom - L->content.top;
    c->maxScroll = max(0, contentH - viewH + S(30)); if (c->scrollY > c->maxScroll) { c->scrollY = c->maxScroll; } if (c->scrollY < 0) { c->scrollY = 0; }
}

static void DrawStatusLine(HDC dc, const Layout* L, WindowCtx* c) {
    HPEN pen = CreatePen(PS_SOLID, S(1), RGB(0,0,0)); HGDIOBJ oldPen = SelectObject(dc, pen);
    MoveToEx(dc, L->content.left, L->content.top, NULL); LineTo(dc, L->content.right, L->content.top); SelectObject(dc, oldPen); DeleteObject(pen);

    HFONT font = NULL; PickClassicFont(&font, 12, FALSE); HGDIOBJ old = SelectObject(dc, font);
    RECT seg = L->content; seg.top += S(2); seg.bottom = seg.top + S(18);
    
    int cnt = 0; ULONGLONG selSize = 0; BOOL hasSelection = FALSE;
    for (int i=0;i<g_itemCount;++i) { if (g_items[i].parent == c->rootId && g_items[i].type != IT_TRASH) { cnt++; if (g_items[i].selected) { hasSelection = TRUE; if (g_items[i].fromFS && g_items[i].path[0]) selSize += FS_GetFileSizeBytes(g_items[i].path); } } }
    ULONGLONG freeSpaceK = 0;
    
    wchar_t currentPath[MAX_PATH] = L"";
    if (c->rootId >= 0 && g_items[c->rootId].fromFS) lstrcpynW(currentPath, g_items[c->rootId].path, MAX_PATH);
    else if (g_fsRootPath[0]) lstrcpynW(currentPath, g_fsRootPath, MAX_PATH);

    if (currentPath[0]) { ULARGE_INTEGER freeBytes; if (GetDiskFreeSpaceExW(currentPath, &freeBytes, NULL, NULL)) freeSpaceK = freeBytes.QuadPart / 1024; }

    RECT lR = seg; lR.left += S(6); lR.right = lR.left + S(300);
    TextOutAlign(dc, lR.left, lR.top + S(2), currentPath[0]?currentPath:L"(Virtual)", TA_LEFT | TA_TOP);

    wchar_t mid[64];
    if (hasSelection) {
        if (selSize < 1024) _snwprintf(mid, 63, L"Sel: %llu B", (unsigned long long)selSize);
        else if (selSize < 1024*1024) _snwprintf(mid, 63, L"Sel: %.2f KB", selSize / 1024.0);
        else if (selSize < 1024*1024*1024) _snwprintf(mid, 63, L"Sel: %.2f MB", selSize / 1048576.0);
        else _snwprintf(mid, 63, L"Sel: %.2f GB", selSize / 1073741824.0);
    } else { _snwprintf(mid, 63, L"%d items", cnt); }
    TextOutAlign(dc, (seg.left+seg.right)/2, seg.top + S(2), mid, TA_TOP | TA_CENTER);
    
    wchar_t right[64];
    if (freeSpaceK > 0) {
        ULONGLONG freeSpaceB = freeSpaceK * 1024ULL;
        if (freeSpaceB < 1024) _snwprintf(right, 63, L"%llu B free", (unsigned long long)freeSpaceB);
        else if (freeSpaceB < 1024*1024) _snwprintf(right, 63, L"%.2f KB free", freeSpaceB / 1024.0);
        else if (freeSpaceB < 1024*1024*1024) _snwprintf(right, 63, L"%.2f MB free", freeSpaceB / 1048576.0);
