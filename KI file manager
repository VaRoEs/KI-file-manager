static void TextOutAlign(HDC dc, int x, int y, const wchar_t* s, UINT align) { UINT old = SetTextAlign(dc, align); TextOutW(dc, x, y, s, lstrlenW(s)); SetTextAlign(dc, old); }

static BOOL FS_IsDotDir(const wchar_t* name) { return (name[0]==L'.' && (name[1]==0 || (name[1]==L'.' && name[2]==0))); }

static ULONGLONG FS_GetFileSizeBytes(const wchar_t* fullPath) {
    WIN32_FILE_ATTRIBUTE_DATA fad;
    if (!fullPath || !*fullPath) return 0;
    if (GetFileAttributesExW(fullPath, GetFileExInfoStandard, &fad)) { ULARGE_INTEGER li; li.HighPart = fad.nFileSizeHigh; li.LowPart  = fad.nFileSizeLow; return li.QuadPart; }
    return 0;
}

static void FS_GetDirSizeRecursive(const wchar_t* dir, ULONGLONG* total) {
    wchar_t mask[MAX_PATH]; _snwprintf(mask, MAX_PATH-1, L"%s\\*", dir); mask[MAX_PATH-1]=0;
    WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd); if (h==INVALID_HANDLE_VALUE) return;
    do {
        if (FS_IsDotDir(fd.cFileName)) continue;
        wchar_t full[MAX_PATH]; _snwprintf(full, MAX_PATH-1, L"%s\\%s", dir, fd.cFileName); full[MAX_PATH-1]=0;
        if (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) FS_GetDirSizeRecursive(full, total);
        else { ULARGE_INTEGER li; li.HighPart = fd.nFileSizeHigh; li.LowPart = fd.nFileSizeLow; *total += li.QuadPart; }
    } while (FindNextFileW(h, &fd)); FindClose(h);
}

static ULONGLONG FS_GetMultiTotalSize(const wchar_t* multi) {
    ULONGLONG t = 0;
    for (const wchar_t* p = multi; *p; p += lstrlenW(p)+1) {
        DWORD attr = GetFileAttributesW(p);
        if (attr != INVALID_FILE_ATTRIBUTES) { if (attr & FILE_ATTRIBUTE_DIRECTORY) FS_GetDirSizeRecursive(p, &t); else t += FS_GetFileSizeBytes(p); }
    } return t;
}

#define MAX_CONCURRENT_OPS 4
typedef struct {
    int slotIdx;
    int opType; 
    wchar_t* multiSrc;
    wchar_t destDir[MAX_PATH];
    volatile ULONGLONG totalBytes;
    volatile ULONGLONG bytesTransferred;
    volatile BOOL isRunning;
    HWND hProgWnd;
    void* copyBuffer;
    DWORD copyBufSize;
} ProgressData;
static ProgressData g_progData[MAX_CONCURRENT_OPS] = {0};

static BOOL MyFileCopy(const wchar_t* srcPath, const wchar_t* dstPath, ProgressData* pd) {
    HANDLE hSrc = CreateFileW(srcPath, GENERIC_READ, FILE_SHARE_READ, NULL, OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hSrc == INVALID_HANDLE_VALUE) return FALSE;
    HANDLE hDst = CreateFileW(dstPath, GENERIC_WRITE, 0, NULL, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
    if (hDst == INVALID_HANDLE_VALUE) { CloseHandle(hSrc); return FALSE; }

    BOOL ok = TRUE; DWORD bytesRead = 0, bytesWritten = 0;
    void* buffer = pd->copyBuffer;
    DWORD bufSize = pd->copyBufSize;
    char stackBuf[8192];
    if (!buffer) { buffer = stackBuf; bufSize = sizeof(stackBuf); }

    while (pd->isRunning && ReadFile(hSrc, buffer, bufSize, &bytesRead, NULL) && bytesRead > 0) {
        if (!WriteFile(hDst, buffer, bytesRead, &bytesWritten, NULL) || bytesRead != bytesWritten) { ok = FALSE; break; }
        pd->bytesTransferred += bytesRead;
    }
    CloseHandle(hDst); CloseHandle(hSrc);

    if (!pd->isRunning || !ok) { DeleteFileW(dstPath); return FALSE; }
    return TRUE;
}

static void MyRecursiveCopy(const wchar_t* srcPath, const wchar_t* dstPath, ProgressData* pd) {
    if (!pd->isRunning) return;
    DWORD attr = GetFileAttributesW(srcPath); if (attr == INVALID_FILE_ATTRIBUTES) return;
    if (attr & FILE_ATTRIBUTE_DIRECTORY) {
        CreateDirectoryW(dstPath, NULL);
        wchar_t mask[MAX_PATH]; _snwprintf(mask, MAX_PATH-1, L"%s\\*", srcPath); mask[MAX_PATH-1]=0;
        WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd);
        if (h != INVALID_HANDLE_VALUE) {
            do {
                if (FS_IsDotDir(fd.cFileName)) continue;
                wchar_t newSrc[MAX_PATH], newDst[MAX_PATH];
                _snwprintf(newSrc, MAX_PATH-1, L"%s\\%s", srcPath, fd.cFileName); _snwprintf(newDst, MAX_PATH-1, L"%s\\%s", dstPath, fd.cFileName);
                MyRecursiveCopy(newSrc, newDst, pd);
            } while (FindNextFileW(h, &fd) && pd->isRunning);
            FindClose(h);
        }
    } else { MyFileCopy(srcPath, dstPath, pd); }
}

static void MyRecursiveDelete(const wchar_t* path, ProgressData* pd) {
    if (!pd->isRunning) return;
    DWORD attr = GetFileAttributesW(path); if (attr == INVALID_FILE_ATTRIBUTES) return;
    if (attr & FILE_ATTRIBUTE_DIRECTORY) {
        wchar_t mask[MAX_PATH]; _snwprintf(mask, MAX_PATH-1, L"%s\\*", path); mask[MAX_PATH-1]=0;
        WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd);
        if (h != INVALID_HANDLE_VALUE) {
            do {
                if (FS_IsDotDir(fd.cFileName)) continue;
                wchar_t child[MAX_PATH]; _snwprintf(child, MAX_PATH-1, L"%s\\%s", path, fd.cFileName);
                MyRecursiveDelete(child, pd);
            } while (FindNextFileW(h, &fd) && pd->isRunning);
            FindClose(h);
        }
        SetFileAttributesW(path, FILE_ATTRIBUTE_NORMAL); RemoveDirectoryW(path);
    } else {
        ULARGE_INTEGER sz; sz.QuadPart = 0; WIN32_FILE_ATTRIBUTE_DATA fad;
        if (GetFileAttributesExW(path, GetFileExInfoStandard, &fad)) { sz.HighPart = fad.nFileSizeHigh; sz.LowPart = fad.nFileSizeLow; }
        SetFileAttributesW(path, FILE_ATTRIBUTE_NORMAL); DeleteFileW(path);
        pd->bytesTransferred += sz.QuadPart;
    }
}

static void MyRecursiveMove(const wchar_t* srcPath, const wchar_t* dstPath, ProgressData* pd) {
    if (!pd->isRunning) return;
    if (MoveFileW(srcPath, dstPath)) { 
        ULONGLONG sz = 0; DWORD attr = GetFileAttributesW(dstPath);
        if (attr != INVALID_FILE_ATTRIBUTES) { if (attr & FILE_ATTRIBUTE_DIRECTORY) FS_GetDirSizeRecursive(dstPath, &sz); else sz = FS_GetFileSizeBytes(dstPath); }
        pd->bytesTransferred += sz;
    } else {
        MyRecursiveCopy(srcPath, dstPath, pd);
        if (pd->isRunning) MyRecursiveDelete(srcPath, pd);
    }
}

static void FS_SplitNameExt(const wchar_t* name, wchar_t* base, wchar_t* ext);
static void FS_PathJoin(wchar_t* out, const wchar_t* dir, const wchar_t* name);

static void FS_UniqueName(wchar_t* out, const wchar_t* dir, const wchar_t* name, BOOL isDir) {
    wchar_t tryPath[MAX_PATH]; FS_PathJoin(tryPath, dir, name);
    DWORD attrs = GetFileAttributesW(tryPath); if (attrs == INVALID_FILE_ATTRIBUTES) { lstrcpynW(out, name, MAX_PATH-1); return; }
    wchar_t base[MAX_PATH], ext[MAX_PATH]; FS_SplitNameExt(name, base, ext);
    for (int i=2; i<1000; ++i) {
        wchar_t candidate[MAX_PATH]; if (ext[0]) wsprintfW(candidate, L"%s (%d)%s", base, i, ext); else wsprintfW(candidate, L"%s (%d)", base, i);
        FS_PathJoin(tryPath, dir, candidate); attrs = GetFileAttributesW(tryPath);
        if (attrs == INVALID_FILE_ATTRIBUTES) { lstrcpynW(out, candidate, MAX_PATH-1); return; }
    } lstrcpynW(out, name, MAX_PATH-1);
}

static DWORD WINAPI FileOpWorker(LPVOID lpParam) {
    ProgressData* pd = (ProgressData*)lpParam;
    pd->totalBytes = FS_GetMultiTotalSize(pd->multiSrc);
    
    pd->copyBufSize = 8 * 1024 * 1024;
    pd->copyBuffer = VirtualAlloc(NULL, pd->copyBufSize, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
    if (!pd->copyBuffer) { 
        pd->copyBufSize = 65536; 
        pd->copyBuffer = VirtualAlloc(NULL, pd->copyBufSize, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE); 
    }

    for (const wchar_t* p = pd->multiSrc; *p; p += lstrlenW(p)+1) {
        if (!pd->isRunning) break;
        if (pd->opType == FO_DELETE) { MyRecursiveDelete(p, pd); } else {
            const wchar_t* fname = wcsrchr(p, L'\\'); if (fname) fname++; else fname = p;
            DWORD srcAttr = GetFileAttributesW(p); BOOL isDir = (srcAttr != INVALID_FILE_ATTRIBUTES && (srcAttr & FILE_ATTRIBUTE_DIRECTORY));
            wchar_t finalName[MAX_PATH]; FS_UniqueName(finalName, pd->destDir, fname, isDir);
            wchar_t dstPath[MAX_PATH]; FS_PathJoin(dstPath, pd->destDir, finalName);
            if (pd->opType == FO_COPY) MyRecursiveCopy(p, dstPath, pd); else if (pd->opType == FO_MOVE) MyRecursiveMove(p, dstPath, pd);
        }
    }
    
    if (pd->copyBuffer) {
        VirtualFree(pd->copyBuffer, 0, MEM_RELEASE);
        pd->copyBuffer = NULL;
    }
    pd->isRunning = FALSE; return 0;
}

static LRESULT CALLBACK ProgressProc(HWND w, UINT m, WPARAM wp, LPARAM lp) {
    ProgressData* pd = (ProgressData*)GetWindowLongPtrW(w, GWLP_USERDATA);
    switch(m) {
        case WM_CREATE: {
            CREATESTRUCT* cs = (CREATESTRUCT*)lp;
            pd = (ProgressData*)cs->lpCreateParams;
            SetWindowLongPtrW(w, GWLP_USERDATA, (LONG_PTR)pd);
            SetTimer(w, 1, 30, NULL);
        } return 0;
        case WM_TIMER: {
            if (pd && !pd->isRunning) {
                KillTimer(w, 1); DestroyWindow(w);
                if (pd->multiSrc) { LocalFree(pd->multiSrc); pd->multiSrc = NULL; }
                PostMessageW(GetParent(w), WM_APP+2, 0, 0); 
            } else { InvalidateRect(w, NULL, FALSE); }
        } return 0;
        case WM_PAINT: {
            PAINTSTRUCT ps; HDC dc = BeginPaint(w, &ps); RECT r; GetClientRect(w, &r);
            HBRUSH bg = CreateSolidBrush(RGB(245,245,245)); FillRect(dc, &r, bg); DeleteObject(bg);
            DrawClassicBezel(dc, r); RECT titleR = r; titleR.bottom = titleR.top + S(24); DrawPinstripe(dc, titleR);

            HFONT f; PickClassicFont(&f, 13, TRUE); HGDIOBJ of = SelectObject(dc, f); SetBkMode(dc, TRANSPARENT);
            TextOutAlign(dc, (titleR.left+titleR.right)/2, titleR.top+S(4), L"File Operation", TA_TOP|TA_CENTER);
            SelectObject(dc, of); DeleteObject(f);

            double pct = 0.0;
            if (pd && pd->totalBytes > 0) { pct = (double)pd->bytesTransferred / (double)pd->totalBytes; }
            else { static float bounce = 0.0f; bounce += 0.02f; if(bounce>1.0f) bounce=0; pct = bounce; }
            if (pct < 0.0) { pct = 0.0; } if (pct > 1.0) { pct = 1.0; }

            RECT barR = { r.left + S(20), titleR.bottom + S(30), r.right - S(20), titleR.bottom + S(50) };
            HPEN pen = CreatePen(PS_SOLID, S(1), RGB(0,0,0)); HGDIOBJ op = SelectObject(dc, pen);
            Rectangle(dc, barR.left, barR.top, barR.right, barR.bottom);
            RECT fillR = barR; InflateRect(&fillR, -S(2), -S(2)); fillR.right = fillR.left + (int)((fillR.right - fillR.left) * pct);
            HBRUSH bfill = CreateSolidBrush(RGB(100, 150, 255)); FillRect(dc, &fillR, bfill); DeleteObject(bfill);

            wchar_t pctStr[32]; _snwprintf(pctStr, 31, L"%.0f%%", pct * 100.0);
            PickClassicFont(&f, 12, FALSE); SelectObject(dc, f);
            TextOutAlign(dc, (barR.left+barR.right)/2, barR.bottom + S(10), pctStr, TA_TOP|TA_CENTER);
            SelectObject(dc, op); DeleteObject(pen); SelectObject(dc, of); DeleteObject(f); EndPaint(w, &ps);
        } return 0;
    }
    return DefWindowProcW(w,m,wp,lp);
}

static void StartFileOperation(int opType, const wchar_t* multiSrc, const wchar_t* destDir, HWND hParent) {
    int slot = -1;
    for (int i=0; i<MAX_CONCURRENT_OPS; i++) { if (!g_progData[i].isRunning) { slot = i; break; } }
    if (slot == -1) { MessageBoxW(hParent, L"Max parallel operations (4) reached!", L"Busy", MB_OK); return; }

    ProgressData* pd = &g_progData[slot];
    pd->opType = opType;
    
    size_t srcBytes = 2;
    for (const wchar_t* p = multiSrc; *p; p += lstrlenW(p)+1) {
        srcBytes += lstrlenW(p) + 1;
    }
    if (pd->multiSrc) { LocalFree(pd->multiSrc); pd->multiSrc = NULL; }
    pd->multiSrc = (wchar_t*)LocalAlloc(LMEM_FIXED, srcBytes * sizeof(wchar_t));
    if (pd->multiSrc) memcpy(pd->multiSrc, multiSrc, srcBytes * sizeof(wchar_t));

    if (destDir) lstrcpyW(pd->destDir, destDir); else pd->destDir[0] = 0;
    pd->totalBytes = 0; pd->bytesTransferred = 0; pd->isRunning = TRUE; pd->slotIdx = slot;
    
    CreateThread(NULL, 0, FileOpWorker, pd, 0, NULL);
    
    RECT wr; GetWindowRect(hParent, &wr);
    pd->hProgWnd = CreateWindowExW(WS_EX_TOOLWINDOW|WS_EX_TOPMOST, kProgClass, L"", WS_POPUP, wr.left + S(100) + slot*S(30), wr.top + S(150) + slot*S(30), S(320), S(110), hParent, NULL, g_hInst, pd);
    ShowWindow(pd->hProgWnd, SW_SHOWNOACTIVATE); UpdateWindow(pd->hProgWnd);
}

static BOOL DoPasteIntoDirViaProgress(HWND owner, const wchar_t* destDir, const wchar_t* textMulti, BOOL isMove) {
    if (!destDir || !*destDir || !textMulti || !*textMulti) return FALSE;
    int maxLines = 16384;
    wchar_t** arr = (wchar_t**)LocalAlloc(LMEM_FIXED, maxLines * sizeof(wchar_t*));
    if (!arr) return FALSE;
    int n = SplitLinesToArray(textMulti, arr, maxLines);
    if (n<=0) { LocalFree(arr); return FALSE; }
    wchar_t* multi = BuildDoubleNullMultiString(arr, n);
    if (!multi) { FreeArray(arr, n); LocalFree(arr); return FALSE; }
    StartFileOperation(isMove ? FO_MOVE : FO_COPY, multi, destDir, owner);
    LocalFree(multi); FreeArray(arr, n); LocalFree(arr); return TRUE;
}

typedef enum { IT_FOLDER, IT_FILE, IT_TRASH, IT_GROUP } ItemType;
typedef struct { ItemType type; wchar_t name[64]; wchar_t desc[128]; int gridCol, gridRow; BOOL selected; int parent; wchar_t path[MAX_PATH]; BOOL fromFS; BOOL scanned; ULONGLONG lastWriteTime; ULONGLONG sizeCache; } Item;

#define MAX_ITEMS 16384
static Item g_items[MAX_ITEMS];
static int  g_itemCount = 0;
static BOOL  g_ttVisible = FALSE;
static int   g_ttItem    = -1;
static POINT g_ttPos     = {0,0};
static int  g_trashIndex = -1;
static wchar_t g_fsRootPath[MAX_PATH] = L"";

typedef struct { BOOL isAdvanced; wchar_t pattern[128]; BOOL hasSizeFilter; int sizeSign; ULONGLONG sizeLimit; BOOL isTop; int topCount; int topSort; } SearchQuery;
typedef struct { wchar_t name[MAX_PATH]; wchar_t path[MAX_PATH]; ULONGLONG size; BOOL isDir; } SearchResultItem;
typedef struct { SearchQuery sq; wchar_t startDir[MAX_PATH]; HWND hwndNotify; volatile BOOL* pRunningFlag; } SearchTask;

static volatile BOOL g_isSearchRunning = FALSE;
static int g_topSortDir = -1;

static void ParseQuery(const wchar_t* q, SearchQuery* sq) {
    memset(sq, 0, sizeof(SearchQuery)); lstrcpyW(sq->pattern, L"*"); 
    sq->topSort = -1;
    
    wchar_t lq[512]; lstrcpynW(lq, q, 511); CharLowerW(lq);
    const wchar_t* pFindAll = wcsstr(lq, L"-findall"); if (!pFindAll) pFindAll = wcsstr(lq, L"findall");
    if (pFindAll) {
        sq->isAdvanced = TRUE; pFindAll += (pFindAll[0] == L'-') ? 8 : 7; while (*pFindAll == L' ' || *pFindAll == L'(') pFindAll++;
        int i = 0; while (*pFindAll && *pFindAll != L' ' && *pFindAll != L')' && i < 126) { sq->pattern[i++] = (*pFindAll == L'@') ? L'*' : q[pFindAll - lq]; pFindAll++; }
        sq->pattern[i] = 0; if (i == 0) lstrcpyW(sq->pattern, L"*");
    }
    const wchar_t* pTop = wcsstr(lq, L"-top"); if (!pTop) pTop = wcsstr(lq, L"top");
    if (pTop) {
        sq->isAdvanced = TRUE; sq->isTop = TRUE; pTop += (pTop[0] == L'-') ? 4 : 3; while (*pTop == L' ') pTop++;
        sq->topCount = _wtoi(pTop); while (*pTop >= L'0' && *pTop <= L'9') pTop++; while (*pTop == L' ') pTop++;
        if (*pTop == L'h') sq->topSort = -1; else if (*pTop == L's') sq->topSort = 1;
    }
    for (const wchar_t* p = lq; *p; p++) {
        if ((*p == L'+' || *p == L'-') && p[1] >= L'0' && p[1] <= L'9') {
            sq->isAdvanced = TRUE; sq->hasSizeFilter = TRUE; sq->sizeSign = (*p == L'+') ? 1 : -1; p++; ULONGLONG val = 0;
            while (*p >= L'0' && *p <= L'9') { val = val * 10 + (*p - L'0'); p++; } while (*p == L' ') p++;
            if (wcsncmp(p, L"gb", 2) == 0) val *= 1024ULL * 1024ULL * 1024ULL; else if (wcsncmp(p, L"mb", 2) == 0) val *= 1024ULL * 1024ULL; else if (wcsncmp(p, L"kb", 2) == 0) val *= 1024ULL;
            sq->sizeLimit = val; break;
        }
    }
    if (!sq->isAdvanced) { int i = 0; for (; q[i] && i < 126; i++) sq->pattern[i] = (q[i] == L'@') ? L'*' : q[i]; sq->pattern[i] = 0; }
}

static int CompareSearchItems(const void* a, const void* b) {
    SearchResultItem* itemA = (SearchResultItem*)a; SearchResultItem* itemB = (SearchResultItem*)b;
    if (itemA->size < itemB->size) return (g_topSortDir == 1) ? -1 : 1;
    if (itemA->size > itemB->size) return (g_topSortDir == 1) ? 1 : -1;
    return 0;
}

static void RecursiveSearchWorker(const wchar_t* dir, SearchTask* task, SearchResultItem* pResults, int* pCount) {
    if (!*(task->pRunningFlag)) return;
    wchar_t mask[MAX_PATH]; if (dir[lstrlenW(dir)-1] == L'\\') _snwprintf(mask, MAX_PATH-1, L"%s*", dir); else _snwprintf(mask, MAX_PATH-1, L"%s\\*", dir);
    WIN32_FIND_DATAW fd; HANDLE h = FindFirstFileW(mask, &fd); if (h == INVALID_HANDLE_VALUE) return;
    do {
        if (lstrcmpW(fd.cFileName, L".") == 0 || lstrcmpW(fd.cFileName, L"..") == 0) continue;
        wchar_t full[MAX_PATH]; if (dir[lstrlenW(dir)-1] == L'\\') _snwprintf(full, MAX_PATH-1, L"%s%s", dir, fd.cFileName); else _snwprintf(full, MAX_PATH-1, L"%s\\%s", dir, fd.cFileName);
        BOOL isDir = (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0; BOOL match = TRUE;
        if (task->sq.pattern[0] && lstrcmpW(task->sq.pattern, L"*") != 0) { if (!PathMatchSpecW(fd.cFileName, task->sq.pattern)) match = FALSE; }
        ULONGLONG sz = 0; if (!isDir) { ULARGE_INTEGER li; li.HighPart = fd.nFileSizeHigh; li.LowPart = fd.nFileSizeLow; sz = li.QuadPart; }
        if (match && task->sq.hasSizeFilter && !isDir) { if (task->sq.sizeSign > 0 && sz <= task->sq.sizeLimit) match = FALSE; if (task->sq.sizeSign < 0 && sz >= task->sq.sizeLimit) match = FALSE; }
        if (match && (!isDir || !task->sq.hasSizeFilter)) {
            if (*pCount < 16000) {
                pResults[*pCount].size = sz; pResults[*pCount].isDir = isDir; lstrcpynW(pResults[*pCount].name, fd.cFileName, MAX_PATH); lstrcpynW(pResults[*pCount].path, full, MAX_PATH); (*pCount)++;
            } else {
                if (task->sq.isTop) {
                    g_topSortDir = task->sq.topSort; qsort(pResults, *pCount, sizeof(SearchResultItem), CompareSearchItems);
                    int keep = (task->sq.topCount > 0 && task->sq.topCount < 8000) ? task->sq.topCount : 1000; *pCount = keep;
                    pResults[*pCount].size = sz; pResults[*pCount].isDir = isDir; lstrcpynW(pResults[*pCount].name, fd.cFileName, MAX_PATH); lstrcpynW(pResults[*pCount].path, full, MAX_PATH); (*pCount)++;
                } else { FindClose(h); return; }
            }
        }
        if (isDir) RecursiveSearchWorker(full, task, pResults, pCount);
    } while (FindNextFileW(h, &fd) && *(task->pRunningFlag));
    FindClose(h);
}

static DWORD WINAPI SearchThread(LPVOID lpParam) {
    SearchTask* task = (SearchTask*)lpParam;
    SearchResultItem* pResults = (SearchResultItem*)LocalAlloc(LMEM_FIXED, 16384 * sizeof(SearchResultItem));
    int count = 0;
    if (lstrcmpW(task->startDir, L"ALL") == 0) {
        wchar_t drives[256]; DWORD r = GetLogicalDriveStringsW(255, drives);
        if (r > 0) {
            wchar_t* p = drives;
            while (*p && *(task->pRunningFlag)) {
                wchar_t rootDir[16]; lstrcpynW(rootDir, p, 15); UINT type = GetDriveTypeW(rootDir);
                if (type == DRIVE_FIXED || type == DRIVE_REMOVABLE || type == DRIVE_RAMDISK) { RecursiveSearchWorker(rootDir, task, pResults, &count); }
                p += lstrlenW(p) + 1;
            }
        }
    } else { RecursiveSearchWorker(task->startDir, task, pResults, &count); }

    if (task->sq.isTop && count > 0) { g_topSortDir = task->sq.topSort; qsort(pResults, count, sizeof(SearchResultItem), CompareSearchItems); if (task->sq.topCount > 0 && count > task->sq.topCount) { count = task->sq.topCount; } }
    PostMessageW(task->hwndNotify, WM_APP+5, (WPARAM)pResults, (LPARAM)count); LocalFree(task); return 0;
}

static BOOL GetDesktopPath(wchar_t* outPath) {
    PWSTR p = NULL; HRESULT hr = SHGetKnownFolderPath(&FOLDERID_Desktop, 0, NULL, &p);
    if (SUCCEEDED(hr) && p) { lstrcpynW(outPath, p, MAX_PATH-1); CoTaskMemFree(p); return TRUE; }
    wchar_t up[MAX_PATH]; DWORD n = GetEnvironmentVariableW(L"USERPROFILE", up, MAX_PATH);
    if (n>0 && n<MAX_PATH) { lstrcpynW(outPath, up, MAX_PATH-1); if (outPath[lstrlenW(outPath)-1] != L'\\') lstrcatW(outPath, L"\\Desktop"); else lstrcatW(outPath, L"Desktop"); return TRUE; }
    lstrcpynW(outPath, L"C:\\", MAX_PATH-1); return FALSE;
}

static void FS_SplitNameExt(const wchar_t* name, wchar_t* base, wchar_t* ext) { const wchar_t* dot = wcsrchr(name, L'.'); if (dot && dot != name) { lstrcpynW(base, name, (int)(dot - name) + 1); lstrcpyW(ext, dot); } else { lstrcpynW(base, name, MAX_PATH-1); ext[0]=0; } }
static void FS_PathJoin(wchar_t* out, const wchar_t* dir, const wchar_t* name) { lstrcpynW(out, dir, MAX_PATH-1); size_t n = wcslen(out); if (n>0 && out[n-1] != L'\\') lstrcatW(out, L"\\"); lstrcatW(out, name); }

static BOOL FS_CreateFolder(const wchar_t* dir, const wchar_t* name, wchar_t* outFull) {
    wchar_t finalName[MAX_PATH]; FS_UniqueName(finalName, dir, name, TRUE); wchar_t full[MAX_PATH]; FS_PathJoin(full, dir, finalName);
    if (CreateDirectoryW(full, NULL)) { if (outFull) lstrcpynW(outFull, full, MAX_PATH-1); return TRUE; } return FALSE;
}

static BOOL FS_CreateEmptyFile(const wchar_t* dir, const wchar_t* name, wchar_t* outFull) {
    wchar_t finalName[MAX_PATH]; FS_UniqueName(finalName, dir, name, FALSE); wchar_t full[MAX_PATH]; FS_PathJoin(full, dir, finalName);
    HANDLE h = CreateFileW(full, GENERIC_WRITE, FILE_SHARE_READ, NULL, CREATE_NEW, FILE_ATTRIBUTE_NORMAL, NULL);
    if (h != INVALID_HANDLE_VALUE) { CloseHandle(h); if (outFull) lstrcpynW(outFull, full, MAX_PATH-1); return TRUE; } return FALSE;
}

