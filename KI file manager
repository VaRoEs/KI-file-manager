static void NextAppendPosition(const Layout* L, int rootId, int* outCol, int* outRow) { int maxRow = 0, maxCol = -1; for (int i=0;i<g_itemCount;++i) { if (g_items[i].parent==rootId && g_items[i].type!=IT_TRASH) { if (g_items[i].gridRow > maxRow) { maxRow = g_items[i].gridRow; maxCol = g_items[i].gridCol; } else if (g_items[i].gridRow == maxRow && g_items[i].gridCol > maxCol) { maxCol = g_items[i].gridCol; } } } int col = (maxCol>=0)?(maxCol+1):0; int row = maxRow; int originX = L->content.left + L->xStart; int usableW = L->content.right - originX; int cols = max(1, usableW / L->colW); if (col>=cols) { col = 0; row++; } *outCol = col; *outRow = row; FindNextFree(L, rootId, outCol, outRow, -1); }
