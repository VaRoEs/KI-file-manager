static BOOL RunWithAssoc(const wchar_t* filePath) {
    EnsureAssocFile();
    const wchar_t* ext = wcsrchr(filePath, L'.');
    if (!ext) return FALSE;

    FILE* f = _wfopen(g_assocFile, L"rt,ccs=UTF-8");
    if (!f) return FALSE;

    wchar_t line[1024];
    BOOL launched = FALSE;
    while (fgetws(line, 1024, f)) {
        wchar_t* p1 = wcsstr(line, L"--");
        if (!p1) continue;
        wchar_t* exeStart = p1 + 2;
        wchar_t* p2 = wcsstr(exeStart, L"--");
        if (!p2) continue;
        *p2 = 0; 
        wchar_t* exts = p2 + 2;

        wchar_t extLower[64]; lstrcpynW(extLower, ext, 63); CharLowerW(extLower);
        wchar_t extsLower[512]; lstrcpynW(extsLower, exts, 511); CharLowerW(extsLower);

        if (wcsstr(extsLower, extLower)) {
            ShellExecuteW(NULL, L"open", exeStart, filePath, NULL, SW_SHOWNORMAL);
            launched = TRUE; break;
        }
    }
    fclose(f);
    return launched;
}

static void DrawFolderIcon(HDC dc, int x, int y, int size) {
    int w = size, h = (int)(size*0.75f);
    int tabW = (int)(w*0.35f), tabH = (int)(h*0.2f);
    int yOff = y + (size - h)/2 + (int)(size*0.05f);
    int s1 = max(1, (int)(size*0.02f)), s2 = max(1, (int)(size*0.04f)), s4 = max(1, (int)(size*0.08f));
    int s8 = max(1, (int)(size*0.15f));

    HBRUSH bShadow = CreateSolidBrush(RGB(180, 180, 180));
    POINT ptShadow[] = { {x+s4, yOff+tabH+s4}, {x+w+s2, yOff+tabH+s4}, {x+w-s2, yOff+h+s4}, {x+s2, yOff+h+s4} };
    HRGN rgnShadow = CreatePolygonRgn(ptShadow, 4, WINDING);
    FillRgn(dc, rgnShadow, bShadow); DeleteObject(rgnShadow); DeleteObject(bShadow);

    HPEN pEdge = CreatePen(PS_SOLID, s1, RGB(160, 120, 40));
    HBRUSH bBack = CreateSolidBrush(RGB(240, 200, 100));
    HGDIOBJ oldP = SelectObject(dc, pEdge);
    HGDIOBJ oldB = SelectObject(dc, bBack);
    POINT ptBack[] = { {x, yOff+tabH}, {x, yOff}, {x+tabW, yOff}, {x+tabW+s4, yOff+tabH}, {x+w, yOff+tabH}, {x+w, yOff+h}, {x, yOff+h} };
    Polygon(dc, ptBack, 7);
    
    HBRUSH bPaper = CreateSolidBrush(RGB(250, 250, 250));
    HPEN pPaper = CreatePen(PS_SOLID, s1, RGB(200, 200, 200));
    SelectObject(dc, bPaper); SelectObject(dc, pPaper);
    Rectangle(dc, x+s4, yOff+tabH-s4, x+w-s8, yOff+h-s4);
    MoveToEx(dc, x+s8, yOff+tabH, NULL); LineTo(dc, x+w-s8-s4, yOff+tabH);
    MoveToEx(dc, x+s8, yOff+tabH+s4, NULL); LineTo(dc, x+w-s8-s8, yOff+tabH+s4);
    
    HBRUSH bFront = CreateSolidBrush(RGB(255, 220, 130));
    HPEN pFront = CreatePen(PS_SOLID, s1, RGB(180, 140, 50));
    SelectObject(dc, bFront); SelectObject(dc, pFront);
    POINT ptFront[] = { {x, yOff+h}, {x+s8, yOff+tabH}, {x+w, yOff+tabH}, {x+w-s8, yOff+h} };
    Polygon(dc, ptFront, 4);

    HPEN pHi = CreatePen(PS_SOLID, s1, RGB(255, 245, 200));
    SelectObject(dc, pHi);
    MoveToEx(dc, x+s8+s1, yOff+tabH+s1, NULL); LineTo(dc, x+w-s2, yOff+tabH+s1);
    
    SelectObject(dc, oldP); SelectObject(dc, oldB);
    DeleteObject(pEdge); DeleteObject(bBack); DeleteObject(bPaper); DeleteObject(pPaper);
    DeleteObject(bFront); DeleteObject(pFront); DeleteObject(pHi);
}

static void DrawFloppyIcon(HDC dc, int x, int y, int size) {
    int w = (int)(size * 0.75f);
    int h = size;
    int dx = x + (size - w)/2;
    int dy = y;
    int fold = (int)(w * 0.3f);
    int s1 = max(1, (int)(size*0.02f)), s3 = max(1, (int)(size*0.05f)), s6 = max(1, (int)(size*0.1f)), s12 = max(1, (int)(size*0.2f));

    HBRUSH bShadow = CreateSolidBrush(RGB(180, 180, 180));
    POINT ptShadow[] = { {dx+s3, dy+s3}, {dx+w+s3, dy+s3+fold}, {dx+w+s3, dy+h+s3}, {dx+s3, dy+h+s3} };
    HRGN rgnShadow = CreatePolygonRgn(ptShadow, 4, WINDING);
    FillRgn(dc, rgnShadow, bShadow); DeleteObject(rgnShadow); DeleteObject(bShadow);

    HBRUSH bPaper = CreateSolidBrush(RGB(255, 255, 255));
    HPEN pEdge = CreatePen(PS_SOLID, s1, RGB(100, 100, 100));
    HGDIOBJ oldP = SelectObject(dc, pEdge);
    HGDIOBJ oldB = SelectObject(dc, bPaper);
    
    POINT ptDoc[] = { {dx, dy}, {dx+w-fold, dy}, {dx+w, dy+fold}, {dx+w, dy+h}, {dx, dy+h} };
    Polygon(dc, ptDoc, 5);

    HBRUSH bFold = CreateSolidBrush(RGB(220, 220, 230));
    SelectObject(dc, bFold);
    POINT ptFold[] = { {dx+w-fold, dy}, {dx+w-fold, dy+fold}, {dx+w, dy+fold} };
    Polygon(dc, ptFold, 3);
    
    MoveToEx(dc, dx+w-fold, dy+fold, NULL); LineTo(dc, dx+w, dy+fold);
    MoveToEx(dc, dx+w-fold, dy+fold, NULL); LineTo(dc, dx+w-fold, dy);

    HPEN pLine = CreatePen(PS_SOLID, s1, RGB(200, 200, 210));
    SelectObject(dc, pLine);
    for (int ly = dy + s12; ly < dy + h - s6; ly += s6) {
        MoveToEx(dc, dx + s6, ly, NULL);
        int lw = (ly < dy + fold + s3) ? (w - fold - s6 - s3) : (w - s12);
        LineTo(dc, dx + s6 + lw, ly);
    }

    SelectObject(dc, oldP); SelectObject(dc, oldB);
    DeleteObject(bPaper); DeleteObject(pEdge); DeleteObject(bFold); DeleteObject(pLine);
}

static void DrawGroupIcon(HDC dc, int x, int y, int size) {
    int w = size, h = (int)(size*0.8f);
    int dy = y + (size-h)/2;
    int s1 = max(1, (int)(size*0.02f)), s4 = max(1, (int)(size*0.08f)), s8 = max(1, (int)(size*0.15f)), s12 = max(1, (int)(size*0.2f));

    HPEN pNone = CreatePen(PS_NULL, 0, 0);
    HBRUSH bShadow = CreateSolidBrush(RGB(180,180,180));
    HGDIOBJ oldP = SelectObject(dc, pNone);
    HGDIOBJ oldB = SelectObject(dc, bShadow);
    RoundRect(dc, x+s4, dy+s4, x+w+s4, dy+h+s4, s8, s8);

    HBRUSH bBase = CreateSolidBrush(RGB(210, 230, 240));
    HPEN pEdge = CreatePen(PS_SOLID, s1, RGB(80, 100, 120));
    SelectObject(dc, bBase); SelectObject(dc, pEdge);
    RoundRect(dc, x, dy, x+w, dy+h, s8, s8);

    HBRUSH bTitle = CreateSolidBrush(RGB(160, 190, 210));
    SelectObject(dc, bTitle);
    POINT ptT[] = { {x+s1, dy+s12}, {x+w-s1, dy+s12}, {x+w-s1, dy+s4}, {x+w-s4, dy+s1}, {x+s4, dy+s1}, {x+s1, dy+s4} };
    Polygon(dc, ptT, 6);
    MoveToEx(dc, x, dy+s12, NULL); LineTo(dc, x+w, dy+s12);

    HBRUSH bItem = CreateSolidBrush(RGB(255, 255, 255));
    SelectObject(dc, bItem);
    int sq = (w - s4*3) / 3;
    int startX = x + s4 + s1;
    int startY = dy + s12 + s4;
    for (int r = 0; r < 2; ++r) {
        for (int c = 0; c < 3; ++c) {
            Rectangle(dc, startX + c*(sq+s4), startY + r*(sq+s4), startX + c*(sq+s4) + sq, startY + r*(sq+s4) + sq);
            MoveToEx(dc, startX + c*(sq+s4) + s1*2, startY + r*(sq+s4) + s4, NULL);
            LineTo(dc, startX + c*(sq+s4) + sq - s1*2, startY + r*(sq+s4) + s4);
        }
    }

    SelectObject(dc, oldP); SelectObject(dc, oldB);
    DeleteObject(pNone); DeleteObject(bShadow); DeleteObject(bBase); DeleteObject(pEdge);
    DeleteObject(bTitle); DeleteObject(bItem);
}

static void DrawTrashIcon(HDC dc, int x, int y, int size, float lidOpenPct) {
